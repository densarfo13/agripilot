{
  "name": "farroway",
  "version": "1.0.2",
  "private": true,
  "type": "module",
  "scripts": {
    "test": "cd server && npm test",
    "dev": "vite",
    "prebuild": "node scripts/build-icons.mjs",
    "build": "vite build && cd server && npx prisma generate && npx tsc -p intelligence/tsconfig.json",
    "postbuild": "node scripts/bake-sw-version.mjs",
    "build:icons": "node scripts/build-icons.mjs",
    "build:intelligence": "cd server && npx tsc -p intelligence/tsconfig.json",
    "start": "node scripts/prisma-deploy-with-baseline.mjs && cd server && node scripts/init-admin.mjs && node src/server.js",
    "postinstall": "[ -d server ] && cd server && npm install || true",
    "db:push": "cd server && npx prisma db push",
    "db:seed": "cd server && node prisma/seed.js",
    "seed:demo": "cd server && node prisma/seed-demo.js",
    "preview": "vite preview",
    "build:android": "vite build && npx cap sync android",
    "android:sync": "npx cap sync android",
    "android:open": "npx cap open android",
    "build:ios": "vite build && npx cap sync ios",
    "ios:sync": "npx cap sync ios",
    "ios:open": "npx cap open ios",
    "guard:prisma":  "node scripts/ci/check-prisma-safety.mjs",
    "guard:migration": "node scripts/ci/check-migration-safety.mjs",
    "guard:crops":   "node scripts/ci/check-crop-type-drift.mjs",
    "guard:i18n":    "node scripts/ci/check-i18n-coverage.mjs",
    "guard:i18n-parity": "node scripts/ci/check-i18n-parity.mjs",
    "guard:duplicate-crops": "node scripts/ci/check-duplicate-crop-sources.mjs",
    "guard:crop-render": "node scripts/ci/check-raw-crop-render.mjs",
    "guard:env":     "node scripts/ci/check-env-assertions.mjs --mode=prod",
    "guards":        "npm run guard:prisma && npm run guard:migration && npm run guard:crops && npm run guard:i18n && npm run guard:i18n-parity && npm run guard:duplicate-crops && npm run guard:crop-render && npm run guard:env",
    "check:i18n":         "node scripts/check-i18n.js",
    "check:crop-labels":  "node scripts/check-raw-crop-render.js",
    "launch-gate":      "node scripts/launch-gate.mjs",
    "launch-gate:fast": "node scripts/launch-gate.mjs --fast --no-build"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/cli": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/geolocation": "^8.2.0",
    "@capacitor/ios": "^8.3.0",
    "axios": "^1.7.9",
    "i18n-iso-countries": "^7.14.0",
    "i18next": "^26.0.6",
    "leaflet": "^1.9.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.4",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.1.1",
    "recharts": "^2.15.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^6.0.7"
  }
}
