{
  "appId": "com.farroway.app",
  "appName": "Farroway",
  "webDir": "dist",
  "server": {
    "androidScheme": "https",
    "iosScheme": "https",
    "hostname": "farroway.app",
    "allowNavigation": ["farroway.app", "*.farroway.app", "farroways.com", "*.farroways.com"]
  },
  "plugins": {
    "CapacitorCookies": {
      "enabled": true
    },
    "CapacitorHttp": {
      "enabled": true
    }
  },
  "android": {
    "allowMixedContent": false,
    "backgroundColor": "#0F172A"
  },
  "ios": {
    "backgroundColor": "#0F172A",
    "contentInset": "automatic",
    "preferredContentMode": "mobile",
    "scheme": "Farroway"
  }
}
