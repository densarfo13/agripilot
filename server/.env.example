# ──────────────────────────────────────────────────
# Farroway Server — Environment Configuration
# Copy to .env and fill in real values before running
# ──────────────────────────────────────────────────

# Database (required)
DATABASE_URL="postgresql://user:password@localhost:5432/farroway?schema=public"

# JWT (required — use a random 64+ char string in production)
JWT_SECRET="CHANGE-THIS-generate-a-real-secret-at-least-64-chars"
JWT_EXPIRES_IN="24h"

# Server
PORT=4000
NODE_ENV=development

# CORS — comma-separated allowed origins (REQUIRED in production)
# In development, leave empty to allow all origins
# In production, set to your frontend domain(s)
# Example: CORS_ORIGIN=https://agripilot-production.up.railway.app,https://app.farroway.com
CORS_ORIGIN=""

# File uploads
UPLOAD_DIR="./uploads"
MAX_FILE_SIZE_MB=10

# ──────────────────────────────────────────────────
# FEDERATED AUTH (optional — features disabled if not set)
# ──────────────────────────────────────────────────

# Google OAuth2
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: {AUTH_CALLBACK_BASE_URL}/api/auth/google/callback
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Microsoft OAuth2
# Register app at: https://portal.azure.com/#blade/Microsoft_AAD_RegisteredApps
# Redirect URI: {AUTH_CALLBACK_BASE_URL}/api/auth/microsoft/callback
# Set MICROSOFT_TENANT_ID to 'common' for multi-tenant, or your org's tenant ID
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
MICROSOFT_TENANT_ID="common"

# Generic OIDC (Okta, Auth0, Keycloak, etc.) — optional
# Callback URI: {AUTH_CALLBACK_BASE_URL}/api/auth/oidc/callback
OIDC_ISSUER_URL=""           # e.g. https://company.okta.com
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_DISPLAY_NAME="Company SSO"
OIDC_SCOPES="openid email profile"

# OAuth state CSRF signing key — optional, falls back to JWT_SECRET
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
OAUTH_STATE_SECRET=""

# Auth callback/redirect URLs
# AUTH_CALLBACK_BASE_URL: where OAuth providers redirect after consent (your server origin)
# FRONTEND_BASE_URL: your frontend origin (for postMessage target in popup flow)
AUTH_CALLBACK_BASE_URL="http://localhost:4000"
FRONTEND_BASE_URL="http://localhost:5173"

# ──────────────────────────────────────────────────
# FARMER INVITE SETTINGS
# ──────────────────────────────────────────────────
# How many days before an invite link expires (default: 7)
INVITE_TOKEN_EXPIRY_DAYS="7"

# ──────────────────────────────────────────────────
# EMAIL DELIVERY (optional — invite links still work without this)
# When configured, invites can be sent by email automatically.
# If NOT configured, invite links must be shared manually (copy/paste).
# Provider: SendGrid — requires both SENDGRID_API_KEY and EMAIL_FROM_ADDRESS.
# ──────────────────────────────────────────────────
SENDGRID_API_KEY=""
EMAIL_FROM_ADDRESS="no-reply@yourdomain.com"
EMAIL_FROM_NAME="Farroway"

# ──────────────────────────────────────────────────
# SMS DELIVERY (optional — invite links still work without this)
# When configured, invite links can be sent via SMS.
# If NOT configured, invite links must be shared manually (copy/paste/WhatsApp).
# Provider: Twilio — requires all three vars.
# ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ──────────────────────────────────────────────────
# MFA (TOTP / Authenticator App)
# MFA_SECRET_KEY: AES-256-GCM key for encrypting TOTP secrets at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# If not set, MFA enrollment is disabled (logged to console in dev).
# ──────────────────────────────────────────────────
MFA_SECRET_KEY=""
MFA_TOTP_ISSUER="Farroway"
MFA_STEP_UP_WINDOW_MINUTES="30"
MFA_CHALLENGE_TOKEN_MINUTES="5"

# ──────────────────────────────────────────────────
# WEATHER INTEGRATION (optional)
# Default provider: Open-Meteo (free, no API key required)
# Weather data enriches farm recommendations with location-aware insights.
# ──────────────────────────────────────────────────
WEATHER_API_KEY=""
WEATHER_BASE_URL="https://api.open-meteo.com/v1"
WEATHER_TIMEOUT_MS="5000"
WEATHER_CACHE_TTL_MINUTES="30"

# ──────────────────────────────────────────────────
# PASSWORD RESET
# Self-service password reset via email (requires SendGrid configured above).
# ──────────────────────────────────────────────────
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES="60"

# ──────────────────────────────────────────────────
# PRODUCTION REQUIREMENTS
# ──────────────────────────────────────────────────
# 1. JWT_SECRET MUST be set (min 32 chars) — server will NOT start without it
# 2. NODE_ENV=production
# 3. CORS_ORIGIN MUST be set to your frontend domain — otherwise only same-origin allowed
# 4. NEVER run seed.js in production — it wipes all data
# 5. Use `npx prisma migrate deploy` instead of `prisma db push` in production
# 6. Password policy: min 8 chars, 1 uppercase, 1 lowercase, 1 digit
# 7. For federated auth: set AUTH_CALLBACK_BASE_URL and FRONTEND_BASE_URL to production URLs
