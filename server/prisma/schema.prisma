generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ──────────────────────────────────────

enum OrganizationType {
  NGO
  LENDER
  COOPERATIVE
  INVESTOR
  DEVELOPMENT_PARTNER
  INTERNAL
}

model Organization {
  id          String            @id @default(uuid())
  name        String
  type        OrganizationType  @default(INTERNAL)
  countryCode String?           @map("country_code")
  regionCode  String?           @map("region_code")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  users                User[]
  farmers              Farmer[]
  approvalRequests     ApprovalRequest[]
  pilotChecklistItems  PilotChecklistItem[]

  @@map("organizations")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  super_admin
  institutional_admin
  reviewer
  field_officer
  investor_viewer
  farmer
}

enum RegistrationStatus {
  pending_approval
  approved
  rejected
  disabled
}

enum LifecycleStage {
  pre_planting
  planting
  vegetative
  flowering
  harvest
  post_harvest
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  needs_more_evidence
  field_review_required
  fraud_hold
  approved
  conditional_approved
  rejected
  escalated
  disbursed
}

enum DecisionType {
  approve
  conditional_approve
  reject
  needs_more_evidence
  field_review_required
  escalate
}

enum FraudRiskLevel {
  low
  medium
  high
  critical
}

enum EvidenceType {
  farm_photo
  id_document
  land_title
  crop_photo
  harvest_receipt
  input_receipt
  other
}

enum FarmActivityType {
  planting
  spraying
  fertilizing
  irrigation
  weeding
  harvesting
  storage
  selling
  other
}

enum ReminderType {
  spraying
  fertilizing
  weeding
  irrigation
  harvesting
  harvest_check
  farm_visit_followup
  evidence_completion
  storage_check
  market_check
  pest_inspection
  drying_reminder
  custom
  general
}

enum NotificationType {
  application_update
  verification_complete
  decision_made
  evidence_needed
  reminder_due
  reminder
  field_visit_scheduled
  harvest_guidance
  storage_alert
  post_harvest
  market
  weather
  buyer_guidance
  system
  general
}

enum StorageMethod {
  sealed_bags
  hermetic_bag
  open_air
  warehouse
  silo
  traditional
  cold_storage
  other
}

enum StorageCondition {
  good
  fair
  poor
  deteriorating
  unknown
}

// ─── SoD / JIT Approval Enums ───────────────────────────

enum ApprovalRequestType {
  season_reopen       // SoD + JIT: reopen a closed/harvested/failed season
  farmer_disable      // SoD: disable a farmer account
  role_escalation     // SoD: assign super_admin or institutional_admin role
  user_org_transfer   // SoD: move a user across organizations
  privileged_reset    // SoD + JIT: force-reset an institutional_admin/super_admin password
}

enum ApprovalStatus {
  pending
  approved
  rejected
  expired
  revoked
  executed
}

// ─── Auth Provider ──────────────────────────────────────

enum AuthProvider {
  local
  google
  microsoft
}

// ─── User ───────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  fullName          String    @map("full_name")
  role              UserRole  @default(field_officer)
  active            Boolean   @default(true)
  archivedAt        DateTime? @map("archived_at")
  organizationId    String?   @map("organization_id")
  preferredLanguage String    @default("en") @map("preferred_language")
  lastLoginMethod   String?   @map("last_login_method")
  lastLoginAt       DateTime? @map("last_login_at")
  // ─── MFA ───────────────────────────────────────────────
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaSecret         String?   @map("mfa_secret")         // AES-encrypted TOTP secret
  mfaEnrolledAt     DateTime? @map("mfa_enrolled_at")
  mfaBackupCodes    String[]  @default([]) @map("mfa_backup_codes")  // bcrypt-hashed backup codes
  // ─── Token revocation ──────────────────────────────────
  tokenVersion      Int       @default(0) @map("token_version")      // bump on logout/disable
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  organization          Organization?       @relation(fields: [organizationId], references: [id])
  farmerProfile         Farmer?             @relation("FarmerUserAccount")
  farmersCreated        Farmer[]            @relation("FarmerCreatedBy")
  applicationsCreated   Application[]       @relation("ApplicationCreatedBy")
  reviewAssignments     ReviewAssignment[]  @relation("ReviewAssignedTo")
  fieldAssignments      Application[]       @relation("FieldOfficerAssigned")
  reviewNotes           ReviewNote[]
  auditLogs             AuditLog[]
  fieldVisits           FieldVisit[]
  federatedIdentities   FederatedIdentity[]
  // SoD / JIT approval relations
  approvalRequestsMade     ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalRequestsApproved ApprovalRequest[] @relation("ApprovalApprovedBy")
  approvalRequestsRevoked  ApprovalRequest[] @relation("ApprovalRevokedBy")
  // Pilot QA
  pilotChecklistItems      PilotChecklistItem[] @relation("PilotChecklistUpdatedBy")
  // Feedback
  feedback                 UserFeedback[]
  // Auth
  passwordResetTokens      PasswordResetToken[]

  @@index([organizationId], map: "idx_users_org")
  @@index([organizationId, role], map: "idx_users_org_role")
  @@map("users")
}

// ─── Password Reset Token ──────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")   // SHA-256 of the raw token
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_pwd_reset_user")
  @@map("password_reset_tokens")
}

// ─── Federated Identity ────────────────────────────────

model FederatedIdentity {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  providerEmail     String       @map("provider_email")
  linkedAt          DateTime     @default(now()) @map("linked_at")
  metadata          Json?

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "uq_fed_provider_account")
  @@index([userId], map: "idx_fed_user")
  @@map("federated_identities")
}

// ─── Farmer ─────────────────────────────────────────────

model Farmer {
  id                   String              @id @default(uuid())
  fullName             String              @map("full_name")
  phone                String
  nationalId           String?             @map("national_id")
  region               String
  district             String?
  village              String?
  countryCode          String              @default("KE") @map("country_code")
  regionCode           String?             @map("region_code")
  preferredLanguage    String              @default("en") @map("preferred_language")
  primaryCrop          String?             @map("primary_crop")
  farmSizeAcres        Float?              @map("farm_size_acres")
  yearsExperience      Int?                @map("years_experience")
  deviceId             String?             @map("device_id")
  organizationId       String?             @map("organization_id")
  createdById          String              @map("created_by_id")
  selfRegistered       Boolean             @default(false) @map("self_registered")
  registrationStatus   RegistrationStatus  @default(pending_approval) @map("registration_status")
  userId               String?             @unique @map("user_id")
  approvedAt           DateTime?           @map("approved_at")
  approvedById         String?             @map("approved_by_id")
  rejectedAt           DateTime?           @map("rejected_at")
  rejectionReason      String?             @map("rejection_reason")
  invitedAt            DateTime?           @map("invited_at")
  inviteToken          String?             @unique @map("invite_token")
  inviteExpiresAt      DateTime?           @map("invite_expires_at")
  inviteChannel        String?             @map("invite_channel")        // 'link', 'email', 'phone'
  inviteDeliveryStatus String?             @map("invite_delivery_status") // 'manual_share_ready','email_sent','phone_sent','accepted','expired'
  inviteAcceptedAt     DateTime?           @map("invite_accepted_at")
  assignedOfficerId    String?             @map("assigned_officer_id")
  currentStage         LifecycleStage      @default(pre_planting) @map("current_stage")
  stageUpdatedAt       DateTime?           @map("stage_updated_at")
  stageSource          String?             @map("stage_source")   // 'activity', 'manual', 'seeded'
  stageConfidence      String?             @map("stage_confidence") // 'high', 'medium', 'low'
  stageCropType        String?             @map("stage_crop_type")
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organization        Organization?       @relation(fields: [organizationId], references: [id])
  createdBy           User                @relation("FarmerCreatedBy", fields: [createdById], references: [id])
  userAccount         User?               @relation("FarmerUserAccount", fields: [userId], references: [id])
  applications        Application[]
  farmActivities      FarmActivity[]
  farmSeasons         FarmSeason[]
  reminders           Reminder[]
  notifications       FarmerNotification[]
  produceStorageStatus ProduceStorageStatus[]
  buyerInterests      BuyerInterest[]
  farmProfiles        FarmProfile[]

  @@index([organizationId], map: "idx_farmers_org")
  @@index([createdById], map: "idx_farmers_created_by")
  @@index([registrationStatus], map: "idx_farmers_reg_status")
  @@index([countryCode], map: "idx_farmers_country")
  @@index([region], map: "idx_farmers_region")
  @@index([currentStage], map: "idx_farmers_stage")
  @@index([assignedOfficerId], map: "idx_farmers_officer")
  @@map("farmers")
}

// ─── Application ────────────────────────────────────────

model Application {
  id                     String            @id @default(uuid())
  farmerId               String            @map("farmer_id")
  createdById            String            @map("created_by_id")
  status                 ApplicationStatus @default(draft)
  cropType               String            @map("crop_type")
  farmSizeAcres          Float             @map("farm_size_acres")
  requestedAmount        Float             @map("requested_amount")
  recommendedAmount      Float?            @map("recommended_amount")
  currencyCode           String            @default("KES") @map("currency_code")
  purpose                String?
  season                 String?
  assignedReviewerId     String?           @map("assigned_reviewer_id")
  assignedFieldOfficerId String?           @map("assigned_field_officer_id")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  farmer              Farmer              @relation(fields: [farmerId], references: [id])
  createdBy           User                @relation("ApplicationCreatedBy", fields: [createdById], references: [id])
  assignedFieldOfficer User?              @relation("FieldOfficerAssigned", fields: [assignedFieldOfficerId], references: [id])
  farmLocation        FarmLocation?
  farmBoundary        FarmBoundary?
  evidenceFiles       EvidenceFile[]
  verificationResult  VerificationResult?
  fraudResult         FraudResult?
  decisionResult      DecisionResult?
  benchmarkResult     BenchmarkResult?
  intelligenceResult  IntelligenceResult?
  reviewAssignments   ReviewAssignment[]
  reviewNotes         ReviewNote[]
  auditLogs           AuditLog[]
  fieldVisits         FieldVisit[]

  @@index([farmerId], map: "idx_applications_farmer")
  @@index([createdById], map: "idx_applications_created_by")
  @@index([status], map: "idx_applications_status")
  @@index([assignedReviewerId], map: "idx_applications_reviewer")
  @@index([assignedFieldOfficerId], map: "idx_applications_officer")
  @@index([createdAt], map: "idx_applications_created_at")
  @@index([status, createdAt], map: "idx_applications_status_created")
  @@index([assignedReviewerId, status], map: "idx_applications_reviewer_status")
  @@map("applications")
}

// ─── Farm Location ──────────────────────────────────────

model FarmLocation {
  id              String   @id @default(uuid())
  applicationId   String   @unique @map("application_id")
  latitude        Float
  longitude       Float
  accuracy        Float?
  altitude        Float?
  capturedAt      DateTime @default(now()) @map("captured_at")
  deviceId        String?  @map("device_id")
  gpsMethod       String?  @map("gps_method")

  application     Application @relation(fields: [applicationId], references: [id])

  @@map("farm_locations")
}

// ─── Farm Boundary ──────────────────────────────────────

model FarmBoundary {
  id              String          @id @default(uuid())
  applicationId   String          @unique @map("application_id")
  measuredArea    Float?          @map("measured_area_acres")
  perimeterMeters Float?          @map("perimeter_meters")
  capturedAt      DateTime        @default(now()) @map("captured_at")

  application     Application     @relation(fields: [applicationId], references: [id])
  points          BoundaryPoint[]

  @@map("farm_boundaries")
}

model BoundaryPoint {
  id          String       @id @default(uuid())
  boundaryId  String       @map("boundary_id")
  pointOrder  Int          @map("point_order")
  latitude    Float
  longitude   Float

  boundary    FarmBoundary @relation(fields: [boundaryId], references: [id], onDelete: Cascade)

  @@index([boundaryId], map: "idx_boundary_points_boundary")
  @@map("boundary_points")
}

// ─── Evidence ───────────────────────────────────────────

model EvidenceFile {
  id              String       @id @default(uuid())
  applicationId   String       @map("application_id")
  type            EvidenceType
  filename        String
  originalName    String       @map("original_name")
  mimeType        String       @map("mime_type")
  sizeBytes       Int          @map("size_bytes")
  url             String
  photoHash       String?      @map("photo_hash")
  metadata        Json?
  uploadedAt      DateTime     @default(now()) @map("uploaded_at")

  application     Application  @relation(fields: [applicationId], references: [id])

  @@index([applicationId], map: "idx_evidence_application")
  @@index([photoHash], map: "idx_evidence_hash")
  @@map("evidence_files")
}

// ─── Verification Result ────────────────────────────────

model VerificationResult {
  id                  String   @id @default(uuid())
  applicationId       String   @unique @map("application_id")
  verificationScore   Float    @map("verification_score")
  confidence          String
  recommendation      String
  flags               Json     @default("[]")
  reasons             Json     @default("[]")
  factors             Json     @default("{}")
  intelligenceSummary Json?    @map("intelligence_summary")
  createdAt           DateTime @default(now()) @map("created_at")

  application         Application @relation(fields: [applicationId], references: [id])

  @@map("verification_results")
}

// ─── Fraud Result ───────────────────────────────────────

model FraudResult {
  id                  String         @id @default(uuid())
  applicationId       String         @unique @map("application_id")
  fraudRiskScore      Float          @map("fraud_risk_score")
  fraudRiskLevel      FraudRiskLevel @map("fraud_risk_level")
  action              String
  flags               Json           @default("[]")
  reasons             Json           @default("[]")
  matchedRecords      Json           @default("[]") @map("matched_records")
  intelligenceSummary Json?          @map("intelligence_summary")
  createdAt           DateTime       @default(now()) @map("created_at")

  application         Application    @relation(fields: [applicationId], references: [id])

  @@map("fraud_results")
}

// ─── Decision Result ────────────────────────────────────

model DecisionResult {
  id                      String       @id @default(uuid())
  applicationId           String       @unique @map("application_id")
  decision                DecisionType
  decisionLabel           String       @map("decision_label")
  riskLevel               String       @map("risk_level")
  recommendedAmount       Float?       @map("recommended_amount")
  blockers                Json         @default("[]")
  reasons                 Json         @default("[]")
  nextActions             Json         @default("[]") @map("next_actions")
  createdAt               DateTime     @default(now()) @map("created_at")

  application             Application  @relation(fields: [applicationId], references: [id])

  @@map("decision_results")
}

// ─── Benchmark Result ───────────────────────────────────

model BenchmarkResult {
  id                      String   @id @default(uuid())
  applicationId           String   @unique @map("application_id")
  peerGroupSize           Int      @map("peer_group_size")
  verificationPercentile  Float?   @map("verification_percentile")
  yieldPercentile         Float?   @map("yield_percentile")
  repaymentPercentile     Float?   @map("repayment_percentile")
  strengths               Json     @default("[]")
  concerns                Json     @default("[]")
  createdAt               DateTime @default(now()) @map("created_at")

  application             Application @relation(fields: [applicationId], references: [id])

  @@map("benchmark_results")
}

// ─── Intelligence Result ────────────────────────────────

model IntelligenceResult {
  id                    String   @id @default(uuid())
  applicationId         String   @unique @map("application_id")
  mlShadowScore         Float?   @map("ml_shadow_score")
  mlShadowConfidence    Float?   @map("ml_shadow_confidence")
  satelliteSignal       Json?    @map("satellite_signal")
  yieldSignal           Json?    @map("yield_signal")
  relationshipSignal    Json?    @map("relationship_signal")
  anomalySignal         Json?    @map("anomaly_signal")
  cropPredictionSignal  Json?    @map("crop_prediction_signal")
  weatherSignal         Json?    @map("weather_signal")
  marketSignal          Json?    @map("market_signal")
  chatbotSignal         Json?    @map("chatbot_signal")
  analyticsSignal       Json?    @map("analytics_signal")
  storageSignal         Json?    @map("storage_signal")
  buyerSignal           Json?    @map("buyer_signal")
  createdAt             DateTime @default(now()) @map("created_at")

  application           Application @relation(fields: [applicationId], references: [id])

  @@map("intelligence_results")
}

// ─── Review Assignment ──────────────────────────────────

model ReviewAssignment {
  id              String    @id @default(uuid())
  applicationId   String    @map("application_id")
  reviewerId      String    @map("reviewer_id")
  assignedAt      DateTime  @default(now()) @map("assigned_at")
  completedAt     DateTime? @map("completed_at")
  status          String    @default("assigned")

  application     Application @relation(fields: [applicationId], references: [id])
  reviewer        User        @relation("ReviewAssignedTo", fields: [reviewerId], references: [id])

  @@index([applicationId], map: "idx_review_assign_app")
  @@index([reviewerId], map: "idx_review_assign_reviewer")
  @@map("review_assignments")
}

// ─── Review Note ────────────────────────────────────────

model ReviewNote {
  id              String   @id @default(uuid())
  applicationId   String   @map("application_id")
  authorId        String   @map("author_id")
  content         String
  internal        Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")

  application     Application @relation(fields: [applicationId], references: [id])
  author          User        @relation(fields: [authorId], references: [id])

  @@index([applicationId], map: "idx_review_notes_app")
  @@index([authorId], map: "idx_review_notes_author")
  @@map("review_notes")
}

// ─── Audit Log ──────────────────────────────────────────

model AuditLog {
  id              String   @id @default(uuid())
  applicationId   String?  @map("application_id")
  userId          String?  @map("user_id")
  organizationId  String?  @map("organization_id")
  action          String
  details         Json?
  previousStatus  String?  @map("previous_status")
  newStatus       String?  @map("new_status")
  ipAddress       String?  @map("ip_address")
  createdAt       DateTime @default(now()) @map("created_at")

  application     Application? @relation(fields: [applicationId], references: [id])
  user            User?        @relation(fields: [userId], references: [id])

  @@index([applicationId], map: "idx_audit_application")
  @@index([userId], map: "idx_audit_user")
  @@index([organizationId], map: "idx_audit_org")
  @@index([action], map: "idx_audit_action")
  @@index([createdAt], map: "idx_audit_created_at")
  @@map("audit_logs")
}

// ─── Field Visit ────────────────────────────────────────

model FieldVisit {
  id              String    @id @default(uuid())
  applicationId   String    @map("application_id")
  officerId       String    @map("officer_id")
  visitDate       DateTime  @map("visit_date")
  notes           String?
  findings        Json?
  completed       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @map("created_at")

  application     Application @relation(fields: [applicationId], references: [id])
  officer         User        @relation(fields: [officerId], references: [id])

  @@index([applicationId], map: "idx_field_visits_app")
  @@index([officerId], map: "idx_field_visits_officer")
  @@map("field_visits")
}

// ─── Portfolio Snapshot ─────────────────────────────────

model PortfolioSnapshot {
  id                     String   @id @default(uuid())
  organizationId         String?  @map("organization_id")
  snapshotDate           DateTime @map("snapshot_date")
  totalApplications      Int      @map("total_applications")
  totalRequestedAmount   Float    @map("total_requested_amount")
  totalRecommendedAmount Float    @map("total_recommended_amount")
  avgVerificationScore   Float?   @map("avg_verification_score")
  decisionMix            Json     @map("decision_mix")
  riskMix                Json     @map("risk_mix")
  statusMix              Json     @map("status_mix")
  topRiskCrops           Json     @map("top_risk_crops")
  topRiskRegions         Json     @map("top_risk_regions")
  createdAt              DateTime @default(now()) @map("created_at")

  @@index([organizationId], map: "idx_portfolio_org")
  @@map("portfolio_snapshots")
}

// ─── Farm Activity ──────────────────────────────────────

model FarmActivity {
  id              String           @id @default(uuid())
  farmerId        String           @map("farmer_id")
  activityType    FarmActivityType @map("activity_type")
  cropType        String?          @map("crop_type")
  description     String?
  quantity        Float?
  unit            String?
  lifecycleStage  LifecycleStage? @map("lifecycle_stage") // stage at time of activity
  metadata        Json?
  activityDate    DateTime         @map("activity_date")
  createdAt       DateTime         @default(now()) @map("created_at")

  farmer          Farmer           @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_activities_farmer")
  @@index([activityType], map: "idx_activities_type")
  @@index([activityDate], map: "idx_activities_date")
  @@index([farmerId, activityDate], map: "idx_activities_farmer_date")
  @@map("farm_activities")
}

// ─── Reminder ───────────────────────────────────────────

model Reminder {
  id              String       @id @default(uuid())
  farmerId        String       @map("farmer_id")
  reminderType    ReminderType @map("reminder_type")
  title           String
  message         String
  dueDate         DateTime     @map("due_date")
  completed       Boolean      @default(false)
  completedAt     DateTime?    @map("completed_at")
  lifecycleStage  LifecycleStage? @map("lifecycle_stage")
  triggerSource   String?         @map("trigger_source") // 'lifecycle_engine', 'activity', 'manual', 'seeded'
  metadata        Json?
  createdAt       DateTime     @default(now()) @map("created_at")

  farmer          Farmer       @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_reminders_farmer")
  @@index([completed], map: "idx_reminders_completed")
  @@index([dueDate], map: "idx_reminders_due")
  @@map("reminders")
}

// ─── Farmer Notification ────────────────────────────────

model FarmerNotification {
  id               String           @id @default(uuid())
  farmerId         String           @map("farmer_id")
  notificationType NotificationType @map("notification_type")
  title            String
  message          String
  read             Boolean          @default(false)
  metadata         Json?
  createdAt        DateTime         @default(now()) @map("created_at")

  farmer           Farmer           @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_notifications_farmer")
  @@index([read], map: "idx_notifications_read")
  @@map("farmer_notifications")
}

// ─── Produce Storage Status ─────────────────────────────

model ProduceStorageStatus {
  id               String           @id @default(uuid())
  farmerId         String           @map("farmer_id")
  cropType         String           @map("crop_type")
  quantityKg       Float?           @map("quantity_kg")
  harvestDate      DateTime?        @map("harvest_date")
  storageMethod    StorageMethod?   @map("storage_method")
  storageCondition StorageCondition @default(unknown) @map("storage_condition")
  readyToSell      Boolean          @default(false) @map("ready_to_sell")
  notes            String?
  metadata         Json?
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")

  farmer           Farmer           @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_storage_farmer")
  @@map("produce_storage_status")
}

// ─── Farm Season (Progress Tracking) ───────────────────

enum SeasonStatus {
  active
  harvested    // harvest report submitted, pending final review/closure
  completed    // fully closed and reviewed
  abandoned    // voluntarily abandoned by farmer
  failed       // crop failure declared
}

enum CropCondition {
  good
  average
  poor
}

enum AdviceFollowed {
  yes
  no
  partial
}

enum PerformanceClassification {
  on_track
  slight_delay
  at_risk
  critical
}

model FarmSeason {
  id                  String         @id @default(uuid())
  farmerId            String         @map("farmer_id")
  cropType            String         @map("crop_type")
  farmSizeAcres       Float          @map("farm_size_acres")
  areaUnit            String         @default("acres") @map("area_unit")
  seedQuantity        Float?         @map("seed_quantity")
  seedType            String?        @map("seed_type")
  plantingDate        DateTime       @map("planting_date")
  expectedHarvestDate DateTime?      @map("expected_harvest_date")
  declaredIntent      String?        @map("declared_intent")
  status              SeasonStatus   @default(active)
  cropFailureReported Boolean        @default(false) @map("crop_failure_reported")
  partialHarvest      Boolean        @default(false) @map("partial_harvest")
  lastActivityDate    DateTime?      @map("last_activity_date")
  closedAt            DateTime?      @map("closed_at")
  closedBy            String?        @map("closed_by")
  closureReason       String?        @map("closure_reason")
  reopenedAt          DateTime?      @map("reopened_at")
  reopenedBy          String?        @map("reopened_by")
  reopenReason        String?        @map("reopen_reason")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  farmer              Farmer         @relation(fields: [farmerId], references: [id])
  progressEntries     SeasonProgressEntry[]
  stageConfirmations  StageConfirmation[]
  harvestReport       HarvestReport?
  progressScore       ProgressScore?
  credibilityAssessment CredibilityAssessment?
  officerValidations  OfficerValidation[]

  @@index([farmerId], map: "idx_seasons_farmer")
  @@index([status], map: "idx_seasons_status")
  @@index([cropType], map: "idx_seasons_crop")
  @@index([status, createdAt], map: "idx_seasons_status_created")
  @@map("farm_seasons")
}

model SeasonProgressEntry {
  id              String           @id @default(uuid())
  seasonId        String           @map("season_id")
  entryType       String           @default("activity") // activity, condition, advice
  activityType    FarmActivityType? @map("activity_type")
  description     String?
  quantity        Float?
  unit            String?
  cropCondition   CropCondition?   @map("crop_condition")
  conditionNotes  String?          @map("condition_notes")
  followedAdvice  AdviceFollowed?  @map("followed_advice")
  adviceNotes     String?          @map("advice_notes")
  imageUrl        String?          @map("image_url")
  imageStage      String?          @map("image_stage") // early_growth, mid_stage, pre_harvest, harvest, storage
  imageUploadedAt DateTime?        @map("image_uploaded_at")
  imageLatitude   Float?           @map("image_latitude")
  imageLongitude  Float?           @map("image_longitude")
  lifecycleStage  LifecycleStage?  @map("lifecycle_stage")
  entryDate       DateTime         @map("entry_date")
  createdAt       DateTime         @default(now()) @map("created_at")

  season          FarmSeason       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_progress_season")
  @@index([entryDate], map: "idx_progress_date")
  @@index([entryType], map: "idx_progress_type")
  @@map("season_progress_entries")
}

model StageConfirmation {
  id              String         @id @default(uuid())
  seasonId        String         @map("season_id")
  expectedStage   LifecycleStage @map("expected_stage")
  confirmedStage  LifecycleStage @map("confirmed_stage")
  isMismatch      Boolean        @default(false) @map("is_mismatch")
  note            String?
  createdAt       DateTime       @default(now()) @map("created_at")

  season          FarmSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_stage_confirm_season")
  @@map("stage_confirmations")
}

model HarvestReport {
  id              String       @id @default(uuid())
  seasonId        String       @unique @map("season_id")
  totalHarvestKg  Float        @map("total_harvest_kg")
  yieldPerAcre    Float?       @map("yield_per_acre")
  salesAmount     Float?       @map("sales_amount")
  salesCurrency   String?      @map("sales_currency")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")

  season          FarmSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("harvest_reports")
}

model ProgressScore {
  id                          String                      @id @default(uuid())
  seasonId                    String                      @unique @map("season_id")
  progressScore               Float                       @map("progress_score")
  riskLevel                   String                      @map("risk_level")
  performanceClassification   PerformanceClassification   @map("performance_classification")
  factors                     Json                        @default("{}")
  reasons                     Json                        @default("[]")
  createdAt                   DateTime                    @default(now()) @map("created_at")
  updatedAt                   DateTime                    @updatedAt @map("updated_at")

  season                      FarmSeason                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("progress_scores")
}

// ─── Credibility & Validation ──────────────────────────

enum CredibilityLevel {
  high_confidence
  medium_confidence
  low_confidence
  needs_review
}

enum ValidationType {
  stage
  condition
  harvest
  milestone
  credibility
}

model CredibilityAssessment {
  id                String           @id @default(uuid())
  seasonId          String           @unique @map("season_id")
  credibilityScore  Float            @map("credibility_score")
  credibilityLevel  CredibilityLevel @map("credibility_level")
  flags             Json             @default("[]")
  reasons           Json             @default("[]")
  confidence        String           @default("medium") // low, medium, high
  evidenceCoverage  Json             @default("{}") @map("evidence_coverage")
  anomalies         Json             @default("[]")
  computedAt        DateTime         @default(now()) @map("computed_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  season            FarmSeason       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("credibility_assessments")
}

model OfficerValidation {
  id                  String         @id @default(uuid())
  seasonId            String         @map("season_id")
  officerId           String         @map("officer_id")
  validationType      ValidationType @map("validation_type")
  confirmedStage      LifecycleStage? @map("confirmed_stage")
  confirmedCondition  CropCondition?  @map("confirmed_condition")
  confirmedHarvest    Boolean?       @map("confirmed_harvest")
  note                String?
  validatedAt         DateTime       @default(now()) @map("validated_at")
  completedAt         DateTime?      @map("completed_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  season              FarmSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_officer_validation_season")
  @@index([officerId], map: "idx_officer_validation_officer")
  @@index([officerId, completedAt], map: "idx_officer_validation_officer_completed")
  @@map("officer_validations")
}

// ─── Buyer Interest ─────────────────────────────────────

model BuyerInterest {
  id               String   @id @default(uuid())
  farmerId         String   @map("farmer_id")
  cropType         String   @map("crop_type")
  quantityKg       Float?   @map("quantity_kg")
  preferredBuyerType String? @map("preferred_buyer_type")
  priceExpectation Float?   @map("price_expectation")
  currencyCode     String   @default("KES") @map("currency_code")
  notes            String?
  status           String   @default("expressed") // expressed, matched, withdrawn
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  farmer           Farmer   @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_buyer_interest_farmer")
  @@map("buyer_interests")
}

// ─── Approval Request (SoD + JIT) ───────────────────────

model ApprovalRequest {
  id              String              @id @default(uuid())
  requestType     ApprovalRequestType @map("request_type")
  status          ApprovalStatus      @default(pending)

  // Actors
  requestedById   String              @map("requested_by_id")
  requestedBy     User                @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedById    String?             @map("approved_by_id")
  approvedBy      User?               @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])
  revokedById     String?             @map("revoked_by_id")
  revokedBy       User?               @relation("ApprovalRevokedBy", fields: [revokedById], references: [id])

  // Organization scope
  organizationId  String?             @map("organization_id")
  organization    Organization?       @relation(fields: [organizationId], references: [id])

  // Target resource (one populated per request type)
  targetUserId    String?             @map("target_user_id")
  targetFarmerId  String?             @map("target_farmer_id")
  targetSeasonId  String?             @map("target_season_id")
  targetData      Json?               @map("target_data")

  // Reason and outcome
  reason          String
  rejectionReason String?             @map("rejection_reason")

  // JIT timing (null means no expiry window — pure SoD)
  expiresAt       DateTime?           @map("expires_at")
  revokedAt       DateTime?           @map("revoked_at")
  executedAt      DateTime?           @map("executed_at")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([requestedById], map: "idx_approval_requested_by")
  @@index([status], map: "idx_approval_status")
  @@index([requestType], map: "idx_approval_type")
  @@index([organizationId], map: "idx_approval_org")
  @@index([targetUserId], map: "idx_approval_target_user")
  @@index([targetFarmerId], map: "idx_approval_target_farmer")
  @@index([targetSeasonId], map: "idx_approval_target_season")
  @@index([expiresAt], map: "idx_approval_expires_at")
  @@map("approval_requests")
}

// ─── Pilot QA Checklist ─────────────────────────────────

enum PilotCheckStatus {
  not_started
  pass
  fail
  blocked
  not_applicable
}

model PilotChecklistItem {
  id             String           @id @default(uuid())
  itemKey        String           @map("item_key")
  category       String
  status         PilotCheckStatus @default(not_started)
  notes          String?
  organizationId String?          @map("organization_id")
  updatedById    String?          @map("updated_by_id")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  organization Organization? @relation(fields: [organizationId], references: [id])
  updatedBy    User?         @relation("PilotChecklistUpdatedBy", fields: [updatedById], references: [id])

  @@unique([itemKey, organizationId], name: "item_org_unique")
  @@index([organizationId], map: "idx_qa_org")
  @@index([category, organizationId], map: "idx_qa_cat_org")
  @@map("pilot_checklist_items")
}

// ─── User Feedback ──────────────────────────────────────

model UserFeedback {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  role        String
  message     String
  context     String?
  severity    String   @default("info") // info, low, medium, high
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id])

  @@index([userId], map: "idx_feedback_user")
  @@index([severity], map: "idx_feedback_severity")
  @@index([createdAt], map: "idx_feedback_created_at")
  @@map("user_feedback")
}

// ─── Pilot Daily Snapshot ───────────────────────────────

model PilotDailySnapshot {
  id                  String   @id @default(uuid())
  organizationId      String?  @map("organization_id")
  snapshotDate        DateTime @map("snapshot_date")
  farmerCount         Int      @map("farmer_count")
  activeCount         Int      @map("active_count")
  updatesCount        Int      @map("updates_count")
  validationsCount    Int      @map("validations_count")
  inviteSentCount     Int      @default(0) @map("invite_sent_count")
  inviteAcceptedCount Int      @default(0) @map("invite_accepted_count")
  riskDistribution    Json     @default("{}") @map("risk_distribution")
  createdAt           DateTime @default(now()) @map("created_at")

  @@unique([organizationId, snapshotDate], name: "snapshot_org_date_unique")
  @@index([organizationId, snapshotDate], map: "idx_snapshot_org_date")
  @@map("pilot_daily_snapshots")
}

// ─── Auto Notification (triggered messaging system) ─────

enum AutoNotifChannel {
  sms
  email
  in_app
}

enum AutoNotifStatus {
  pending
  sent
  failed
  skipped     // rate-limited or opted-out
}

enum AutoNotifType {
  invite_reminder         // farmer invited but not accepted after N days
  no_first_update         // no first progress entry after planting
  stale_farmer            // no activity for N days
  validation_pending      // season awaiting officer validation
  reviewer_backlog        // reviewer has too many pending applications
  high_risk_alert         // season risk level is Critical or High
}

model AutoNotification {
  id             String          @id @default(uuid())
  organizationId String?         @map("organization_id")
  userId         String?         @map("user_id")          // target staff user (null = all in org/role)
  roleTarget     String?         @map("role_target")       // 'field_officer' | 'reviewer' | etc.
  farmerId       String?         @map("farmer_id")
  seasonId       String?         @map("season_id")
  type           AutoNotifType
  channel        AutoNotifChannel
  subject        String?
  message        String
  status         AutoNotifStatus @default(pending)
  attempts       Int             @default(0)
  sentAt         DateTime?       @map("sent_at")
  failureReason  String?         @map("failure_reason")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  @@index([organizationId], map: "idx_autonotif_org")
  @@index([userId], map: "idx_autonotif_user")
  @@index([farmerId], map: "idx_autonotif_farmer")
  @@index([type, status], map: "idx_autonotif_type_status")
  @@index([createdAt], map: "idx_autonotif_created_at")
  @@map("auto_notifications")
}

// ─── Farm Profile (MVP persistence) ────────────────────

enum FarmCrop {
  maize
  rice
  cassava
  wheat
}

enum FarmStage {
  planting
  growing
  flowering
  harvest
}

enum RecommendationStatus {
  pending
  completed
  skipped
}

model FarmProfile {
  id              String    @id @default(uuid())
  farmerId        String    @map("farmer_id")
  farmerName      String    @map("farmer_name")
  farmName        String?   @map("farm_name")
  locationName    String?   @map("location_name")
  latitude        Float?
  longitude       Float?
  crop            FarmCrop
  farmSizeAcres   Float?    @map("farm_size_acres")
  stage           FarmStage @default(planting)
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  farmer          Farmer    @relation(fields: [farmerId], references: [id])
  recommendations RecommendationRecord[]
  weatherSnapshots WeatherSnapshot[]
  financeScores   FarmFinanceScore[]

  @@index([farmerId], map: "idx_farm_profiles_farmer")
  @@index([crop], map: "idx_farm_profiles_crop")
  @@map("farm_profiles")
}

model RecommendationRecord {
  id                String               @id @default(uuid())
  farmProfileId     String               @map("farm_profile_id")
  title             String
  action            String
  urgency           String?
  confidence        Float?
  reason            String?
  nextReviewDays    Int?                 @map("next_review_days")
  score             Float?
  status            RecommendationStatus @default(pending)
  farmerNote        String?              @map("farmer_note")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  farmProfile       FarmProfile          @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)

  @@index([farmProfileId], map: "idx_rec_records_farm")
  @@index([status], map: "idx_rec_records_status")
  @@index([farmProfileId, createdAt], map: "idx_rec_records_farm_created")
  @@map("recommendation_records")
}

// ─── Weather Snapshot (lean cache) ─────────────────────

model WeatherSnapshot {
  id              String   @id @default(uuid())
  farmProfileId   String   @map("farm_profile_id")
  latitude        Float
  longitude       Float
  temperatureC    Float    @map("temperature_c")
  rainForecastMm  Float    @map("rain_forecast_mm")
  humidityPct     Float?   @map("humidity_pct")
  windSpeedKmh    Float?   @map("wind_speed_kmh")
  condition       String?
  forecastDays    Int      @default(3) @map("forecast_days")
  source          String   @default("open-meteo")
  fetchedAt       DateTime @default(now()) @map("fetched_at")

  farmProfile     FarmProfile @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)

  @@index([farmProfileId], map: "idx_weather_farm")
  @@index([fetchedAt], map: "idx_weather_fetched")
  @@map("weather_snapshots")
}

// ─── Farm Finance Score ────────────────────────────────

model FarmFinanceScore {
  id              String   @id @default(uuid())
  farmProfileId   String   @map("farm_profile_id")
  score           Int
  band            String
  readiness       String
  confidence      String   @default("medium")
  factors         Json     @default("[]")
  nextSteps       Json     @default("[]") @map("next_steps")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  farmProfile     FarmProfile @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)

  @@index([farmProfileId], map: "idx_finance_score_farm")
  @@index([farmProfileId, createdAt], map: "idx_finance_score_farm_created")
  @@map("farm_finance_scores")
}
