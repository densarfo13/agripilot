// ─── Farm Season (Progress Tracking) ───────────────────

enum SeasonStatus {
  active
  harvested    // harvest report submitted, pending final review/closure
  completed    // fully closed and reviewed
  abandoned    // voluntarily abandoned by farmer
  failed       // crop failure declared
}

enum CropCondition {
  good
  average
  poor
}

enum AdviceFollowed {
  yes
  no
  partial
}

enum PerformanceClassification {
  on_track
  slight_delay
  at_risk
  critical
}

model FarmSeason {
  id                  String         @id @default(uuid())
  farmerId            String         @map("farmer_id")
  cropType            String         @map("crop_type")
  farmSizeAcres       Float          @map("farm_size_acres")
  areaUnit            String         @default("acres") @map("area_unit")
  landSizeValue       Float?         @map("land_size_value")
  landSizeUnit        String?        @map("land_size_unit")       // ACRE | HECTARE | SQUARE_METER
  landSizeHectares    Float?         @map("land_size_hectares")   // normalized value
  seedQuantity        Float?         @map("seed_quantity")
  seedType            String?        @map("seed_type")
  plantingDate        DateTime       @map("planting_date")
  expectedHarvestDate DateTime?      @map("expected_harvest_date")
  declaredIntent      String?        @map("declared_intent")
  status              SeasonStatus   @default(active)
  cropFailureReported Boolean        @default(false) @map("crop_failure_reported")
  partialHarvest      Boolean        @default(false) @map("partial_harvest")
  lastActivityDate    DateTime?      @map("last_activity_date")
  closedAt            DateTime?      @map("closed_at")
  closedBy            String?        @map("closed_by")          // userId of closer — audit trail, no @relation (historical integrity)
  closureReason       String?        @map("closure_reason")
  reopenedAt          DateTime?      @map("reopened_at")
  reopenedBy          String?        @map("reopened_by")        // userId of reopener — audit trail, no @relation (historical integrity)
  reopenReason        String?        @map("reopen_reason")
  createdAt           DateTime       @default(now()) @map("created_at")
  updatedAt           DateTime       @updatedAt @map("updated_at")

  farmer              Farmer         @relation(fields: [farmerId], references: [id])
  progressEntries     SeasonProgressEntry[]
  stageConfirmations  StageConfirmation[]
  harvestReport       HarvestReport?
  progressScore       ProgressScore?
  credibilityAssessment CredibilityAssessment?
  officerValidations  OfficerValidation[]

  @@index([farmerId], map: "idx_seasons_farmer")
  @@index([status], map: "idx_seasons_status")
  @@index([cropType], map: "idx_seasons_crop")
  @@index([status, createdAt], map: "idx_seasons_status_created")
  @@map("farm_seasons")
}

model SeasonProgressEntry {
  id              String           @id @default(uuid())
  seasonId        String           @map("season_id")
  entryType       String           @default("activity") // activity, condition, advice
  activityType    FarmActivityType? @map("activity_type")
  description     String?
  quantity        Float?
  unit            String?
  cropCondition   CropCondition?   @map("crop_condition")
  conditionNotes  String?          @map("condition_notes")
  followedAdvice  AdviceFollowed?  @map("followed_advice")
  adviceNotes     String?          @map("advice_notes")
  imageUrl        String?          @map("image_url")
  imageStage      String?          @map("image_stage") // early_growth, mid_stage, pre_harvest, harvest, storage
  imageUploadedAt DateTime?        @map("image_uploaded_at")
  imageLatitude   Float?           @map("image_latitude")
  imageLongitude  Float?           @map("image_longitude")
  lifecycleStage  LifecycleStage?  @map("lifecycle_stage")
  entryDate       DateTime         @map("entry_date")
  createdAt       DateTime         @default(now()) @map("created_at")

  season          FarmSeason       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_progress_season")
  @@index([entryDate], map: "idx_progress_date")
  @@index([entryType], map: "idx_progress_type")
  @@map("season_progress_entries")
}

model StageConfirmation {
  id              String         @id @default(uuid())
  seasonId        String         @map("season_id")
  expectedStage   LifecycleStage @map("expected_stage")
  confirmedStage  LifecycleStage @map("confirmed_stage")
  isMismatch      Boolean        @default(false) @map("is_mismatch")
  note            String?
  createdAt       DateTime       @default(now()) @map("created_at")

  season          FarmSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_stage_confirm_season")
  @@map("stage_confirmations")
}

model HarvestReport {
  id              String       @id @default(uuid())
  seasonId        String       @unique @map("season_id")
  totalHarvestKg  Float        @map("total_harvest_kg")
  yieldPerAcre    Float?       @map("yield_per_acre")
  salesAmount     Float?       @map("sales_amount")
  salesCurrency   String?      @map("sales_currency")
  notes           String?
  createdAt       DateTime     @default(now()) @map("created_at")

  season          FarmSeason   @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("harvest_reports")
}

model ProgressScore {
  id                          String                      @id @default(uuid())
  seasonId                    String                      @unique @map("season_id")
  progressScore               Float                       @map("progress_score")
  riskLevel                   String                      @map("risk_level")
  performanceClassification   PerformanceClassification   @map("performance_classification")
  factors                     Json                        @default("{}")
  reasons                     Json                        @default("[]")
  createdAt                   DateTime                    @default(now()) @map("created_at")
  updatedAt                   DateTime                    @updatedAt @map("updated_at")

  season                      FarmSeason                  @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("progress_scores")
}

// ─── Credibility & Validation ──────────────────────────

enum CredibilityLevel {
  high_confidence
  medium_confidence
  low_confidence
  needs_review
}

enum ValidationType {
  stage
  condition
  harvest
  milestone
  credibility
}

model CredibilityAssessment {
  id                String           @id @default(uuid())
  seasonId          String           @unique @map("season_id")
  credibilityScore  Float            @map("credibility_score")
  credibilityLevel  CredibilityLevel @map("credibility_level")
  flags             Json             @default("[]")
  reasons           Json             @default("[]")
  confidence        String           @default("medium") // low, medium, high
  evidenceCoverage  Json             @default("{}") @map("evidence_coverage")
  anomalies         Json             @default("[]")
  computedAt        DateTime         @default(now()) @map("computed_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  season            FarmSeason       @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("credibility_assessments")
}

model OfficerValidation {
  id                  String         @id @default(uuid())
  seasonId            String         @map("season_id")
  officerId           String         @map("officer_id")
  validationType      ValidationType @map("validation_type")
  confirmedStage      LifecycleStage? @map("confirmed_stage")
  confirmedCondition  CropCondition?  @map("confirmed_condition")
  confirmedHarvest    Boolean?       @map("confirmed_harvest")
  note                String?
  latitude            Float?
  longitude           Float?
  locationAccuracy    Float?         @map("location_accuracy")
  validatedAt         DateTime       @default(now()) @map("validated_at")
  completedAt         DateTime?      @map("completed_at")
  createdAt           DateTime       @default(now()) @map("created_at")

  season              FarmSeason     @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  officer             User           @relation("ValidationOfficer", fields: [officerId], references: [id])

  @@index([seasonId], map: "idx_officer_validation_season")
  @@index([officerId], map: "idx_officer_validation_officer")
  @@index([officerId, completedAt], map: "idx_officer_validation_officer_completed")
  @@unique([seasonId, officerId, validationType], map: "uq_officer_validation_season_officer_type")
  @@map("officer_validations")
}

// ─── Buyer Interest ─────────────────────────────────────

model BuyerInterest {
  id               String   @id @default(uuid())
  farmerId         String   @map("farmer_id")
  cropType         String   @map("crop_type")
  quantityKg       Float?   @map("quantity_kg")
  preferredBuyerType String? @map("preferred_buyer_type")
  priceExpectation Float?   @map("price_expectation")
  currencyCode     String   @default("KES") @map("currency_code")
  notes            String?
  status           String   @default("expressed") // expressed, matched, withdrawn
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  farmer           Farmer   @relation(fields: [farmerId], references: [id])

  @@index([farmerId], map: "idx_buyer_interest_farmer")
  @@map("buyer_interests")
}

// ─── Approval Request (SoD + JIT) ───────────────────────

model ApprovalRequest {
  id              String              @id @default(uuid())
  requestType     ApprovalRequestType @map("request_type")
  status          ApprovalStatus      @default(pending)

  // Actors
  requestedById   String              @map("requested_by_id")
  requestedBy     User                @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
  approvedById    String?             @map("approved_by_id")
  approvedBy      User?               @relation("ApprovalApprovedBy", fields: [approvedById], references: [id])
  revokedById     String?             @map("revoked_by_id")
  revokedBy       User?               @relation("ApprovalRevokedBy", fields: [revokedById], references: [id])

  // Organization scope
  organizationId  String?             @map("organization_id")
  organization    Organization?       @relation(fields: [organizationId], references: [id])

  // Target resource (one populated per request type)
  targetUserId    String?             @map("target_user_id")
  targetFarmerId  String?             @map("target_farmer_id")
  targetSeasonId  String?             @map("target_season_id")
  targetData      Json?               @map("target_data")

  // Reason and outcome
  reason          String
  rejectionReason String?             @map("rejection_reason")

  // JIT timing (null means no expiry window — pure SoD)
  expiresAt       DateTime?           @map("expires_at")
  revokedAt       DateTime?           @map("revoked_at")
  executedAt      DateTime?           @map("executed_at")

  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  @@index([requestedById], map: "idx_approval_requested_by")
  @@index([status], map: "idx_approval_status")
  @@index([requestType], map: "idx_approval_type")
  @@index([organizationId], map: "idx_approval_org")
  @@index([targetUserId], map: "idx_approval_target_user")
  @@index([targetFarmerId], map: "idx_approval_target_farmer")
  @@index([targetSeasonId], map: "idx_approval_target_season")
  @@index([expiresAt], map: "idx_approval_expires_at")
  @@map("approval_requests")
}

