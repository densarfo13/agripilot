  updatedAt   DateTime @default(now()) @map("updated_at")

  @@map("v2_scoring_config")
}

// ── Onboarding Events (audit trail) ──

model OnboardingEvent {
  id             String   @id @default(uuid())
  userId         String   @map("user_id")
  eventType      String   @map("event_type")       // started, step_completed, completed, abandoned, resumed
  stepName       String?  @map("step_name")         // welcome, farmName, country, crop, farmSize, gender, age, location, photo, processing
  metadataJson   Json?    @map("metadata_json")     // e.g. { source: 'self_register', device: 'mobile' }
