// ─── Auto Notification (triggered messaging system) ─────

enum AutoNotifChannel {
  sms
  email
  in_app
}

enum AutoNotifStatus {
  pending
  sent
  failed
  skipped     // rate-limited or opted-out
}

enum AutoNotifType {
  invite_reminder         // farmer invited but not accepted after N days
  no_first_update         // no first progress entry after planting
  stale_farmer            // no activity for N days
  validation_pending      // season awaiting officer validation
  reviewer_backlog        // reviewer has too many pending applications
  high_risk_alert         // season risk level is Critical or High
  onboarding_reminder     // user started onboarding but hasn't completed after N days
  feedback_followup       // pest report created 5+ days ago with no feedback submitted
}

model AutoNotification {
  id             String          @id @default(uuid())
  organizationId String?         @map("organization_id")
  userId         String?         @map("user_id")          // target staff user (null = all in org/role)
  roleTarget     String?         @map("role_target")       // 'field_officer' | 'reviewer' | etc.
  farmerId       String?         @map("farmer_id")
  seasonId       String?         @map("season_id")
  type           AutoNotifType
  channel        AutoNotifChannel
  subject        String?
  message        String
  status         AutoNotifStatus @default(pending)
  attempts       Int             @default(0)
  sentAt         DateTime?       @map("sent_at")
  failureReason  String?         @map("failure_reason")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  targetUser     User?           @relation("AutoNotifTargetUser", fields: [userId], references: [id])

  @@index([organizationId], map: "idx_autonotif_org")
  @@index([userId], map: "idx_autonotif_user")
  @@index([farmerId], map: "idx_autonotif_farmer")
  @@index([type, status], map: "idx_autonotif_type_status")
  @@index([createdAt], map: "idx_autonotif_created_at")
  @@map("auto_notifications")
}

// ─── Farm Profile (MVP persistence) ────────────────────

// FarmCrop enum removed — crop field is now a plain String to support
// the full A-Z crop list plus "other:CustomName" values.

enum FarmStage {
  planning
  land_preparation
  planting
  germination
  vegetative
  flowering
  fruiting
  harvest
  post_harvest
  // Legacy values kept for migration safety:
  growing        // maps to vegetative
}

enum RecommendationStatus {
  pending
  completed
  skipped
}

model FarmProfile {
  id              String    @id @default(uuid())
  farmerId        String?   @map("farmer_id")
  userId          String?   @map("user_id_direct")   // direct User relation for cookie-based auth flow
  farmerUuid      String?   @unique @map("farmer_uuid")
  farmerName      String    @map("farmer_name")
  farmName        String?   @map("farm_name")
  country         String?   @map("country")
  locationName    String?   @map("location_name")
  latitude        Float?
  longitude       Float?
  locationLabel   String?   @map("location_label")   // cached reverse-geocoded label e.g. "Accra, Ghana"
  crop            String
  // ─── NGO program tag ─────────────────────────────────
  program         String?                             // mirrors User.program for farms created via NGO import
  farmSizeAcres   Float?    @map("farm_size_acres")
  landSizeValue   Float?    @map("land_size_value")
  landSizeUnit    String?   @map("land_size_unit")       // ACRE | HECTARE | SQUARE_METER
  landSizeHectares Float?   @map("land_size_hectares")   // normalized value
  stage           FarmStage @default(planning)
  plantedAt       DateTime? @map("planted_at")
  // ─── Seasonal timing (per-farm calendar) ─────────────
  seasonStartMonth         Int?      @map("season_start_month")          // 1–12
  seasonEndMonth           Int?      @map("season_end_month")            // 1–12
  plantingWindowStartMonth Int?      @map("planting_window_start_month") // 1–12
  plantingWindowEndMonth   Int?      @map("planting_window_end_month")   // 1–12
  currentSeasonLabel       String?   @map("current_season_label")        // e.g. "Main Season 2026"
  lastRainySeasonStart     DateTime? @map("last_rainy_season_start")
  lastDrySeasonStart       DateTime? @map("last_dry_season_start")
  status          String    @default("active") @map("status")  // active | inactive | archived
  isDefault       Boolean   @default(false) @map("is_default")
  experienceLevel String?   @map("experience_level")   // "new" | "experienced" — null = not answered

  // ─── U.S. state-aware onboarding (used by /api/v2/recommend/us) ─
  // These are nullable so non-U.S. farms and legacy rows keep working.
  stateCode      String?  @map("state_code")        // "TX" | "MD" | ... | "DC"
  farmType       String?  @map("farm_type")         // "backyard" | "small_farm" | "commercial"
  beginnerLevel  String?  @map("beginner_level")    // "beginner" | "intermediate" | "advanced"
  growingStyle   String?  @map("growing_style")     // "container" | "raised_bed" | "in_ground" | "mixed"
  farmPurpose    String?  @map("farm_purpose")      // "home_food" | "sell_locally" | "learning" | "mixed"

  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  clientUpdatedAt  DateTime? @map("client_updated_at") // Timestamp from client device for conflict ordering

  farmer          Farmer?   @relation(fields: [farmerId], references: [id])
  userDirect      User?     @relation("DirectFarmProfile", fields: [userId], references: [id])
  seasons         V2Season[]
  recommendations RecommendationRecord[]
  weatherSnapshots WeatherSnapshot[]
  financeScores   FarmFinanceScore[]
  supplyReadiness V2SupplyReadiness[]
  landBoundaries  V2LandBoundary[]
  seedScans       V2SeedScan[]
  landInsights    V2LandInsight[]
  verificationSignals V2VerificationSignal[]
  // Intelligence relations
  cropCycles        V2CropCycle[]
  pestImages        V2PestImage[]
  pestReports       V2PestReport[]
  satelliteScans    V2SatelliteScan[]
  fieldStressScores V2FieldStressScore[]
  hotspotZones      V2HotspotZone[]
  droneScans        V2DroneScan[]
  treatmentActions  V2TreatmentAction[]
  farmPestRisks     V2FarmPestRisk[]
  harvestRecords    V2HarvestRecord[]
  costRecords       V2FarmCostRecord[]
  taskCompletions   V2FarmTaskCompletion[]

  @@index([farmerId], map: "idx_farm_profiles_farmer")
  @@index([userId], map: "idx_farm_profiles_user")
  @@index([crop], map: "idx_farm_profiles_crop")
  @@index([status], map: "idx_farm_profiles_status")
  @@index([userId, isDefault], map: "idx_farm_profiles_default")
  @@map("farm_profiles")
}

// ─── Learned crop usage (adaptive crop suggestions) ────────
model CropUsage {
  id          String   @id @default(uuid())
  cropCode    String   @map("crop_code")       // "MAIZE" or "OTHER:Teff"
  cropName    String   @map("crop_name")       // normalized display name: "Maize" or "Teff"
  country     String?  @map("country")         // country for region-aware suggestions
  region      String?  @map("region")          // region/county for finer targeting
  useCount    Int      @default(1) @map("use_count")
  lastUsedAt  DateTime @default(now()) @map("last_used_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@unique([cropCode, country], map: "uq_crop_usage_code_country")
  @@index([country], map: "idx_crop_usage_country")
  @@index([useCount], map: "idx_crop_usage_count")
  @@map("crop_usage")
}

model RecommendationRecord {
  id                String               @id @default(uuid())
  farmProfileId     String               @map("farm_profile_id")
  title             String
  action            String
  urgency           String?
  confidence        Float?
  reason            String?
  nextReviewDays    Int?                 @map("next_review_days")
  score             Float?
  status            RecommendationStatus @default(pending)
  farmerNote        String?              @map("farmer_note")
  createdAt         DateTime             @default(now()) @map("created_at")
  updatedAt         DateTime             @updatedAt @map("updated_at")

  farmProfile       FarmProfile          @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)
  feedback          RecommendationFeedback[]

  @@index([farmProfileId], map: "idx_rec_records_farm")
  @@index([status], map: "idx_rec_records_status")
  @@index([farmProfileId, createdAt], map: "idx_rec_records_farm_created")
  @@map("recommendation_records")
}

// ─── Weather Snapshot (lean cache) ─────────────────────

model WeatherSnapshot {
  id              String    @id @default(uuid())
  farmProfileId   String    @map("farm_profile_id")
  latitude        Float
  longitude       Float
  temperatureC    Float     @map("temperature_c")
  rainForecastMm  Float     @map("rain_forecast_mm")
  humidityPct     Float?    @map("humidity_pct")
  windSpeedKmh    Float?    @map("wind_speed_kmh")
  condition       String?
  forecastDays    Int       @default(3) @map("forecast_days")
  source          String    @default("open-meteo")
  rainExpected    Boolean?  @map("rain_expected")
  heavyRainRisk   Boolean?  @map("heavy_rain_risk")
  drySpellRisk    Boolean?  @map("dry_spell_risk")
  forecastDate    DateTime? @map("forecast_date")
  fetchedAt       DateTime  @default(now()) @map("fetched_at")

  farmProfile     FarmProfile @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)

  @@index([farmProfileId], map: "idx_weather_farm")
  @@index([fetchedAt], map: "idx_weather_fetched")
  @@map("weather_snapshots")
}

// ─── Farm Finance Score ────────────────────────────────

model FarmFinanceScore {
  id              String   @id @default(uuid())
  farmProfileId   String   @map("farm_profile_id")
  score           Int
  band            String
  readiness       String
  confidence      String   @default("medium")
  factors         Json     @default("[]")
  nextSteps       Json     @default("[]") @map("next_steps")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  farmProfile     FarmProfile @relation(fields: [farmProfileId], references: [id], onDelete: Cascade)

  @@index([farmProfileId], map: "idx_finance_score_farm")
  @@index([farmProfileId, createdAt], map: "idx_finance_score_farm_created")
  @@map("farm_finance_scores")
}

// ─── Referral ──────────────────────────────────────────

model Referral {
  id           String   @id @default(uuid())
  referrerId   String   @map("referrer_id")
  refereeId    String   @map("referee_id")
  code         String   @unique
  status       String   @default("joined") // joined, active
  createdAt    DateTime @default(now()) @map("created_at")

  referrer     User     @relation("ReferralGiver", fields: [referrerId], references: [id])
  referee      User     @relation("ReferralReceiver", fields: [refereeId], references: [id])

  @@index([referrerId], map: "idx_referral_referrer")
  @@index([refereeId], map: "idx_referral_referee")
  @@index([code], map: "idx_referral_code")
  @@unique([referrerId, refereeId], map: "uq_referral_pair")
  @@map("referrals")
}

// ─── Recommendation Feedback ───────────────────────────

model RecommendationFeedback {
  id                 String   @id @default(uuid())
  recommendationId   String   @map("recommendation_id")
  userId             String?  @map("user_id")
  helpful            Boolean
  note               String?
  createdAt          DateTime @default(now()) @map("created_at")

  recommendation     RecommendationRecord @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId], map: "idx_rec_feedback_rec")
  @@unique([recommendationId, userId], map: "uq_rec_feedback_rec_user")
  @@map("recommendation_feedback")
}

// ─── Analytics Event ───────────────────────────────────

model AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])

  @@index([event], map: "idx_analytics_event")
  @@index([userId], map: "idx_analytics_user")
  @@index([createdAt], map: "idx_analytics_created")
  @@map("analytics_events")
}

// ─── Issue Escalation ─────────────────────────────────

enum IssueType {
  BUG
  DATA_ISSUE
  ACCESS_ISSUE
  FEATURE_REQUEST
}

enum IssueCategory {
  BLOCKER
  FRICTION
  TRUST
  FEATURE
}

enum IssuePriority {
  HIGH
  MEDIUM
  LOW
}

enum IssueStatus {
  OPEN
  IN_PROGRESS
  FIXED
  VERIFIED
}

model Issue {
  id              String        @id @default(uuid())
  orgId           String?       @map("org_id")
  userId          String        @map("user_id")
  issueType       IssueType     @map("issue_type")
  category        IssueCategory @default(FRICTION)
  priority        IssuePriority @default(MEDIUM)
  description     String
  status          IssueStatus   @default(OPEN)
  pageRoute       String?       @map("page_route")
  adminNote       String?       @map("admin_note")
  resolutionNote  String?       @map("resolution_note")
  assignedToId    String?       @map("assigned_to_id")
  firstResponseAt DateTime?     @map("first_response_at")
  resolvedAt      DateTime?     @map("resolved_at")
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  user         User          @relation("IssueReporter", fields: [userId], references: [id])
  assignedTo   User?         @relation("IssueAssignee", fields: [assignedToId], references: [id])
  organization Organization? @relation(fields: [orgId], references: [id])
  comments     IssueComment[]
  attachments  IssueAttachment[]

  @@index([userId], map: "idx_issues_user")
  @@index([orgId], map: "idx_issues_org")
  @@index([assignedToId], map: "idx_issues_assignee")
  @@index([status], map: "idx_issues_status")
  @@index([issueType], map: "idx_issues_type")
  @@index([category], map: "idx_issues_category")
  @@index([priority], map: "idx_issues_priority")
  @@index([createdAt], map: "idx_issues_created")
  @@map("issues")
}

model IssueComment {
  id        String   @id @default(uuid())
  issueId   String   @map("issue_id")
  userId    String   @map("user_id")
  text      String
  createdAt DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation("IssueCommenter", fields: [userId], references: [id])

  @@index([issueId], map: "idx_issue_comments_issue")
  @@map("issue_comments")
}

model IssueAttachment {
  id          String   @id @default(uuid())
  issueId     String   @map("issue_id")
  userId      String   @map("user_id")
  filename    String
  originalName String  @map("original_name")
  mimeType    String   @map("mime_type")
  sizeBytes   Int      @map("size_bytes")
  createdAt   DateTime @default(now()) @map("created_at")

  issue Issue @relation(fields: [issueId], references: [id], onDelete: Cascade)
  user  User  @relation("IssueUploader", fields: [userId], references: [id])

  @@index([issueId], map: "idx_issue_attachments_issue")
  @@map("issue_attachments")
}

model StaffNotification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String
  title     String
  message   String
  metadata  Json?
  read      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation("StaffNotifications", fields: [userId], references: [id])

  @@index([userId, read], map: "idx_staff_notif_user_read")
  @@index([createdAt], map: "idx_staff_notif_created")
  @@map("staff_notifications")
}

// ─── System Settings (key-value config store) ──────────

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("system_settings")
}

// ─── V2 Season Engine ─────────────────────────────────

model V2Season {
  id            String    @id @default(uuid())
  userId        String    @map("user_id")
  farmProfileId String?   @map("farm_profile_id")
  cropType      String    @map("crop_type")
  startDate     DateTime  @map("start_date")
  stage         String    @default("planting")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  farmProfile FarmProfile? @relation(fields: [farmProfileId], references: [id])
  tasks       V2Task[]

  @@index([userId], map: "idx_v2_seasons_user")
  @@index([farmProfileId], map: "idx_v2_seasons_farm_profile")
  @@index([isActive], map: "idx_v2_seasons_active")
  @@map("v2_seasons")
}

model V2Task {
  id          String    @id @default(uuid())
  seasonId    String    @map("season_id")
  title       String
  description String?
  status      String    @default("pending")
  dueDate     DateTime  @map("due_date")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  season V2Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@index([seasonId], map: "idx_v2_tasks_season")
  @@index([status], map: "idx_v2_tasks_status")
  @@index([dueDate], map: "idx_v2_tasks_due")
  @@map("v2_tasks")
}

// ─── V2 Farm Task Completions ──────────────────────────────
model V2FarmTaskCompletion {
  id            String   @id @default(uuid())
  userId        String   @map("user_id")
  farmId        String   @map("farm_id")
  taskRuleId    String   @map("task_rule_id")    // e.g. "stage-planning-choose-seed"
  taskId        String   @map("task_id")          // e.g. "stage-planning-choose-seed-farmId"
  title         String
  priority      String?
  actionType    String?  @map("action_type")
  status          String   @default("completed")    // completed | skipped
  completedAt     DateTime @default(now()) @map("completed_at")
  createdAt       DateTime @default(now()) @map("created_at")
  idempotencyKey  String?  @map("idempotency_key")  // Client-generated UUID for dedup
  clientCreatedAt DateTime? @map("client_created_at") // Timestamp from client device

  user User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  farm FarmProfile @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, taskRuleId], map: "uq_farm_task_completion")
  @@index([userId], map: "idx_v2_farm_task_completions_user")
  @@index([farmId], map: "idx_v2_farm_task_completions_farm")
  @@index([completedAt], map: "idx_v2_farm_task_completions_date")
  @@index([idempotencyKey], map: "idx_v2_farm_task_completions_idem")
  @@map("v2_farm_task_completions")
}

// ─── V2 Analytics ──────────────────────────────────────────
model V2AnalyticsEvent {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  event     String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_v2_analytics_user")
  @@index([event], map: "idx_v2_analytics_event")
  @@index([createdAt], map: "idx_v2_analytics_created")
  @@map("v2_analytics_events")
}

// ─── V2 Support Requests ───────────────────────────────────
model V2SupportRequest {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  subject   String
  message   String
  status    String   @default("open")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_v2_support_user")
  @@index([status], map: "idx_v2_support_status")
  @@map("v2_support_requests")
}

// ─── V2 Supply Readiness (lightweight sell-readiness per profile) ────

model V2SupplyReadiness {
  id                  String    @id @default(uuid())
  profileId           String    @map("profile_id")
  readyToSell         Boolean   @default(false) @map("ready_to_sell")
  crop                String
  estimatedQuantity   Float?    @map("estimated_quantity")
  quantityUnit        String    @default("kg") @map("quantity_unit")  // kg | bags | tonnes | crates
  expectedHarvestDate DateTime? @map("expected_harvest_date")
  priceExpectation    Float?    @map("price_expectation")
  currency            String    @default("GHS")
  qualityNotes        String?   @map("quality_notes")
  status              String    @default("active")                     // active | connected | withdrawn
  connectedAt         DateTime? @map("connected_at")
  connectedBy         String?   @map("connected_by")                  // admin userId who marked connected
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  profile             FarmProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  buyerLinks          V2BuyerLink[]

  @@unique([profileId, crop, status], map: "uq_supply_profile_crop_active")
  @@index([profileId], map: "idx_v2_supply_profile")
  @@index([readyToSell], map: "idx_v2_supply_ready")
  @@index([status], map: "idx_v2_supply_status")
  @@map("v2_supply_readiness")
}

// ─── V2 Land Boundary (linked to FarmProfile, not Application) ──────

model V2LandBoundary {
  id                  String              @id @default(uuid())
  profileId           String              @map("profile_id")
  captureMethod       String              @map("capture_method")   // manual_pin | gps_walk | officer_assisted | fallback_pin
  measuredArea        Float?              @map("measured_area_hectares") // normalized hectares
  perimeterMeters     Float?              @map("perimeter_meters")
  pointCount          Int                 @default(0) @map("point_count")
  capturedAt          DateTime            @default(now()) @map("captured_at")
  capturedBy          String?             @map("captured_by")      // userId of capturer (officer or self)
  notes               String?
  // Boundary validation
  boundaryConfidence  Float?              @map("boundary_confidence")    // 0–100
  validationStatus    String              @default("pending") @map("validation_status") // pending | valid | invalid | needs_redraw
  validationReason    String?             @map("validation_reason")
  createdAt           DateTime            @default(now()) @map("created_at")
  updatedAt           DateTime            @updatedAt @map("updated_at")

  profile         FarmProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  points          V2BoundaryPoint[]

  @@index([profileId], map: "idx_v2_land_boundaries_profile")
  @@index([validationStatus], map: "idx_v2_land_boundaries_validation")
  @@map("v2_land_boundaries")
}

model V2BoundaryPoint {
  id          String          @id @default(uuid())
  boundaryId  String          @map("boundary_id")
  pointOrder  Int             @map("point_order")
  latitude    Float
  longitude   Float
  accuracy    Float?          // GPS accuracy in meters

  boundary    V2LandBoundary  @relation(fields: [boundaryId], references: [id], onDelete: Cascade)

  @@index([boundaryId], map: "idx_v2_boundary_points_boundary")
  @@map("v2_boundary_points")
}

// ─── V2 Seed Scan ──────────────────────────────────────────────

model V2SeedScan {
  id              String    @id @default(uuid())
  profileId       String    @map("profile_id")
  scanMethod      String    @map("scan_method")       // qr | barcode | manual
  seedType        String?   @map("seed_type")          // maize, rice, cassava, etc.
  variety         String?
  supplier        String?
  batchNumber     String?   @map("batch_number")
  expiryDate      DateTime? @map("expiry_date")
  rawScanData     String?   @map("raw_scan_data")      // raw QR/barcode payload
  authenticity    String    @default("unknown")         // unknown | verified | warning | failed
  authenticityMsg String?   @map("authenticity_msg")    // human-readable reason
  scannedAt       DateTime  @default(now()) @map("scanned_at")
  scannedBy       String?   @map("scanned_by")          // userId
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  profile         FarmProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId], map: "idx_v2_seed_scans_profile")
  @@index([authenticity], map: "idx_v2_seed_scans_auth")
  @@map("v2_seed_scans")
}

// ─── V2 Land Insight (satellite / remote sensing placeholder) ───

model V2LandInsight {
  id            String    @id @default(uuid())
  profileId     String    @map("profile_id")
  insightType   String    @map("insight_type")    // vegetation_index | land_use | change_detection | soil_moisture
  source        String    @default("pending")      // pending | sentinel2 | landsat | manual
  value         Json?                              // structured data (NDVI, classification, etc.)
  confidence    Float?                             // 0-1
  observedAt    DateTime? @map("observed_at")      // when satellite captured
  generatedAt   DateTime  @default(now()) @map("generated_at")

  profile       FarmProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId], map: "idx_v2_land_insights_profile")
  @@index([insightType], map: "idx_v2_land_insights_type")
  @@map("v2_land_insights")
}

// ─── V2 Verification Signal (generic internal signal model) ─────

model V2VerificationSignal {
  id            String    @id @default(uuid())
  profileId     String    @map("profile_id")
  signalType    String    @map("signal_type")     // boundary_mismatch | seed_auth_warning | area_discrepancy | satellite_anomaly
  severity      String    @default("info")         // info | warning | critical
  message       String
  details       Json?                              // structured context
  resolved      Boolean   @default(false)
  resolvedAt    DateTime? @map("resolved_at")
  resolvedBy    String?   @map("resolved_by")
  createdAt     DateTime  @default(now()) @map("created_at")

  profile       FarmProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId], map: "idx_v2_signals_profile")
  @@index([signalType], map: "idx_v2_signals_type")
  @@index([resolved], map: "idx_v2_signals_resolved")
  @@map("v2_verification_signals")
}

// ─── V2 Buyer (admin-managed buyer records) ───────────────────

model V2Buyer {
  id              String    @id @default(uuid())
  buyerName       String    @map("buyer_name")
  companyName     String?   @map("company_name")
  contactName     String?   @map("contact_name")
  phone           String?
  email           String?
  cropsInterested String?   @map("crops_interested")       // comma-separated crop list
  regionsCovered  String?   @map("regions_covered")        // comma-separated region list
  notes           String?
  createdBy       String    @map("created_by")             // admin userId
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  buyerLinks      V2BuyerLink[]

  @@index([createdBy], map: "idx_v2_buyer_created_by")
  @@map("v2_buyers")
}

// ─── V2 Buyer Link (admin links buyer ↔ sale-ready supply) ────

model V2BuyerLink {
  id              String    @id @default(uuid())
  supplyId        String    @map("supply_id")
  buyerId         String    @map("buyer_id")
  linkedBy        String    @map("linked_by")              // admin userId
  linkedAt        DateTime  @default(now()) @map("linked_at")
  status          String    @default("buyer_linked")       // buyer_linked | buyer_contacted | in_discussion | matched | closed | cancelled
  notes           String?
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  supply          V2SupplyReadiness @relation(fields: [supplyId], references: [id], onDelete: Cascade)
  buyer           V2Buyer           @relation(fields: [buyerId], references: [id], onDelete: Cascade)

  @@unique([supplyId, buyerId], map: "uq_buyer_link_supply_buyer")
  @@index([supplyId], map: "idx_v2_buyer_link_supply")
  @@index([buyerId], map: "idx_v2_buyer_link_buyer")
  @@index([status], map: "idx_v2_buyer_link_status")
  @@map("v2_buyer_links")
}

// ═══════════════════════════════════════════════════════════════
//  INTELLIGENCE — Crop Threat Detection, Satellite, Drone, Alerts
// ═══════════════════════════════════════════════════════════════

model V2CropCycle {
  id                  String    @id @default(uuid())
  profileId           String    @map("profile_id")
  cropType            String    @map("crop_type")
  variety             String?
  plantingDate        DateTime  @map("planting_date")
  expectedHarvestDate DateTime? @map("expected_harvest_date")
  growthStage         String    @default("seedling") @map("growth_stage")
  // Lifecycle status — see CropCycleStatus enum. Nullable until we
  // backfill existing rows; new writes set it explicitly.
  lifecycleStatus     CropCycleStatus? @map("lifecycle_status")
  statusReason        String?          @map("status_reason")   // short note for delayed/failed
  // Action-driven risk band updated by the feedback loop on every
  // meaningful farmer action. Nullable so existing rows stay valid.
  riskBand            String?          @map("risk_band")       // low | medium | high
  updatedAt           DateTime  @updatedAt @map("updated_at")
  createdAt           DateTime  @default(now()) @map("created_at")

  profile             FarmProfile  @relation(fields: [profileId], references: [id], onDelete: Cascade)
  pestReports         V2PestReport[]
  issueReports        IssueReport[]
  verificationRecords VerificationRecord[]
  taskPlans           CycleTaskPlan[]
  recommendationSnapshot RecommendationSnapshot?

  @@index([profileId], map: "idx_v2_crop_cycle_profile")
  @@index([lifecycleStatus], map: "idx_v2_crop_cycle_lifecycle")
  @@index([riskBand], map: "idx_v2_crop_cycle_risk_band")
  @@map("v2_crop_cycles")
}

// ─── Crop lifecycle status enum ──────────────────────────────
enum CropCycleStatus {
  planned
  planting
  growing
  flowering
  harvest_ready
  harvested
  delayed
  failed
}

// ─── Per-cycle task plan (pending work) ──────────────────────
// Separate from V2FarmTaskCompletion (which is completion-only).
// This model tracks the forward-looking plan — one row per
// week-indexed task template so the Today feed can surface
// "what's due now" without re-deriving from crop logic.
model CycleTaskPlan {
  id            String    @id @default(uuid())
  cropCycleId   String    @map("crop_cycle_id")
  title         String
  detail        String?
  weekIndex     Int       @map("week_index")         // 0 = planting week, 1 = week 1, ...
  dueDate       DateTime? @map("due_date")
  status        String    @default("pending")         // pending | completed | skipped | overdue
  priority      String    @default("medium")          // low | medium | high
  completedAt   DateTime? @map("completed_at")
  completedBy   String?   @map("completed_by")
  note          String?
  isTodayTask   Boolean   @default(false) @map("is_today_task")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  cropCycle V2CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)

  @@index([cropCycleId], map: "idx_cycle_task_plan_cycle")
  @@index([status], map: "idx_cycle_task_plan_status")
  @@index([dueDate], map: "idx_cycle_task_plan_due")
  @@map("cycle_task_plans")
}

// ─── NGO intervention queue ─────────────────────────────────
// One row per farm/cycle intervention that the intervention engine
// thinks needs human attention. Persisted so staff can triage and
// reviewer actions have an audit trail.
model Intervention {
  id                  String   @id @default(uuid())
  farmProfileId       String   @map("farm_profile_id")
  cropCycleId         String?  @map("crop_cycle_id")
  interventionScore   Int      @map("intervention_score")     // 0..100
  priority            String                                    // critical | high | medium | low
  reason              String
  recommendedAction   String   @map("recommended_action")
  dueAt               DateTime? @map("due_at")
  status              String   @default("open")                 // open | in_progress | resolved | dismissed
  assignedTo          String?  @map("assigned_to")
  resolvedAt          DateTime? @map("resolved_at")
  reviewerNote        String?  @map("reviewer_note")
  signals             Json?                                      // structured blob of what fired the score
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([farmProfileId], map: "idx_intervention_farm")
  @@index([priority], map: "idx_intervention_priority")
  @@index([status], map: "idx_intervention_status")
  @@index([createdAt], map: "idx_intervention_created")
  @@map("interventions")
}

// ─── Farmer scorecard (aggregate over all their activity) ────
// One row per farmProfile. Recomputed on demand; not normalized
// to status transitions so we can regenerate cheaply.
model FarmerScore {
  id                 String   @id @default(uuid())
  farmProfileId      String   @unique @map("farm_profile_id")
  performanceScore   Int      @map("performance_score")  // 0..100
  consistencyScore   Int      @map("consistency_score")  // 0..100
  riskScore          Int      @map("risk_score")         // 0..100 (higher = riskier)
  verificationScore  Int      @map("verification_score") // 0..100
  healthScore        Int      @map("health_score")       // weighted composite 0..100
  scoreBand          String   @map("score_band")         // excellent | good | fair | weak
  signals            Json?                                // input-counts used to compute scores
  computedAt         DateTime @default(now()) @map("computed_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([scoreBand], map: "idx_farmer_score_band")
  @@index([healthScore], map: "idx_farmer_score_health")
  @@map("farmer_scores")
}

// ─── Funding eligibility decision ───────────────────────────
model FundingDecision {
  id                 String   @id @default(uuid())
  farmProfileId      String   @map("farm_profile_id")
  decision           String                               // eligible | monitor | not_yet_eligible | needs_review
  reason             String
  healthScore        Int?     @map("health_score")
  verificationScore  Int?     @map("verification_score")
  blockers           Json?                                // string[] of soft blockers
  reviewerStatus     String   @default("pending") @map("reviewer_status")  // pending | approved | rejected
  reviewerNote       String?  @map("reviewer_note")
  decidedAt          DateTime @default(now()) @map("decided_at")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([farmProfileId], map: "idx_funding_decision_farm")
  @@index([decision], map: "idx_funding_decision_outcome")
  @@index([reviewerStatus], map: "idx_funding_decision_reviewer")
  @@map("funding_decisions")
}

// ─── Recommendation snapshot (frozen at cycle-creation time) ─
// When a farmer picks a recommendation and starts a crop cycle,
// we freeze the full recommendation payload here so their plan
// stays stable even if the underlying scoring rules change later.
model RecommendationSnapshot {
  id             String   @id @default(uuid())
  cropCycleId    String   @unique @map("crop_cycle_id")
  score          Int
  cropKey        String   @map("crop_key")
  cropName       String   @map("crop_name")
  stateCode      String?  @map("state_code")
  farmType       String?  @map("farm_type")
  why            Json?                                  // reasons[]
  riskNotes      Json?    @map("risk_notes")
  plantingWindow Json?    @map("planting_window")
  harvestWindow  Json?    @map("harvest_window")
  tags           Json?
  rawPayload     Json?    @map("raw_payload")           // full source blob for auditability
  createdAt      DateTime @default(now()) @map("created_at")

  cropCycle V2CropCycle @relation(fields: [cropCycleId], references: [id], onDelete: Cascade)

  @@map("recommendation_snapshots")
}

// ─── Issue reports (farmer-reported problems) ────────────────
// Captures a farmer's "something is wrong" signal — pest, disease,
// weather damage, etc. Feeds the NGO risk summary + acts as input
// for future guidance. Keep the schema flat so non-technical staff
// can triage rows directly in Prisma Studio.
model IssueReport {
  id               String   @id @default(uuid())
  farmProfileId    String   @map("farm_profile_id")
  cropCycleId      String?  @map("crop_cycle_id")
  farmerId         String?  @map("farmer_id")
  category         String                                // pest | disease | weather | water | soil | other
  severity         String   @default("medium")           // low | medium | high
  description      String
  photoUrl         String?  @map("photo_url")
  latitude         Float?
  longitude        Float?
  reportedAt       DateTime @default(now()) @map("reported_at")
  resolvedAt       DateTime? @map("resolved_at")
  status           String   @default("open")             // open | in_review | resolved | ignored
  reviewerNote     String?  @map("reviewer_note")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  cropCycle        V2CropCycle? @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)

  @@index([farmProfileId], map: "idx_issue_report_farm")
  @@index([farmerId], map: "idx_issue_report_farmer")
  @@index([status], map: "idx_issue_report_status")
  @@index([severity], map: "idx_issue_report_severity")
  @@index([reportedAt], map: "idx_issue_report_reported")
  @@map("issue_reports")
}

// ─── Verification records (NGO field audit trail) ────────────
// Lightweight, append-only ledger documenting that a farmer's
// claimed data (planting, harvest, issue) has been independently
// verified — field visit, photo upload, peer confirmation, or
// automated signal. Makes the NGO dashboard defensible without
// requiring a full KYC workflow yet.
model VerificationRecord {
  id               String   @id @default(uuid())
  farmProfileId    String   @map("farm_profile_id")
  cropCycleId      String?  @map("crop_cycle_id")
  subjectType      String   @map("subject_type")          // planting | harvest | issue | task | profile
  subjectId        String?  @map("subject_id")            // PK of the thing being verified, opaque
  method           String                                 // field_visit | photo | peer | automated | document
  verifiedBy       String   @map("verified_by")           // userId | 'system' | 'peer:<farmerId>'
  verifiedAt       DateTime @default(now()) @map("verified_at")
  outcome          String   @default("confirmed")         // confirmed | rejected | inconclusive
  confidence       Float?                                 // 0..1 for automated signals
  evidenceUrl      String?  @map("evidence_url")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")

  cropCycle        V2CropCycle? @relation(fields: [cropCycleId], references: [id], onDelete: SetNull)

  @@index([farmProfileId], map: "idx_verification_farm")
  @@index([subjectType, subjectId], map: "idx_verification_subject")
  @@index([verifiedAt], map: "idx_verification_verified")
  @@map("verification_records")
}

// ─── Farmer action feedback loop ─────────────────────────────
// Append-only ledger of every meaningful action a farmer takes so
// the Today engine can feed recency/streak/skip-rate back into task
// ranking, and the recommendation tuner (future) can compare input
// behavior against harvest outcomes.
model FarmerActionLog {
  id            String   @id @default(uuid())
  farmProfileId String?  @map("farm_profile_id")
  cropCycleId   String?  @map("crop_cycle_id")
  userId        String?  @map("user_id")
  actionType    String   @map("action_type")      // task_completed | task_skipped | issue_reported | harvest_reported
  subjectType   String?  @map("subject_type")     // task | issue | harvest
  subjectId     String?  @map("subject_id")
  details       Json?
  occurredAt    DateTime @default(now()) @map("occurred_at")
  createdAt     DateTime @default(now()) @map("created_at")

  @@index([farmProfileId], map: "idx_action_log_farm")
  @@index([cropCycleId], map: "idx_action_log_cycle")
  @@index([actionType], map: "idx_action_log_type")
  @@index([occurredAt], map: "idx_action_log_time")
  @@map("farmer_action_logs")
}

// ─── Harvest outcome (durable result per cycle) ──────────────
// Stores the end state of a crop cycle for future recommendation
// tuning. One row per cycle — upserted when the farmer submits a
// harvest report. Fields after `notes` are pre-aggregated from the
// task plan + action log so the tuner doesn't have to re-scan.
model HarvestOutcome {
  id                  String   @id @default(uuid())
  farmProfileId       String?  @map("farm_profile_id")
  cropCycleId         String   @unique @map("crop_cycle_id")
  cropKey             String?  @map("crop_key")
  actualYieldKg       Float?   @map("actual_yield_kg")
  yieldUnit           String   @default("kg") @map("yield_unit")
  qualityBand         String?  @map("quality_band")       // poor | fair | good | excellent
  completedTasksCount Int?     @map("completed_tasks_count")
  skippedTasksCount   Int?     @map("skipped_tasks_count")
  overdueTasksCount   Int?     @map("overdue_tasks_count")
  issueCount          Int?     @map("issue_count")
  issueTags           Json?    @map("issue_tags")         // string[] e.g. ['pest','drought']
  harvestedAt         DateTime? @map("harvested_at")      // farmer-reported harvest date
  outcomeClass        String?   @map("outcome_class")      // successful | delayed | high_risk | failed
  notes               String?
  reportedAt          DateTime @default(now()) @map("reported_at")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  @@index([farmProfileId], map: "idx_harvest_outcome_farm")
  @@index([cropKey], map: "idx_harvest_outcome_crop")
  @@index([qualityBand], map: "idx_harvest_outcome_quality")
  @@index([outcomeClass], map: "idx_harvest_outcome_class")
  @@map("harvest_outcomes")
}

// ─── Marketplace v1: structured buyer/farmer matching ───────
// Not an open marketplace — every interest routes through the
// farmer's acceptance before contact is revealed.
model CropListing {
  id             String    @id @default(uuid())
  farmerId       String    @map("farmer_id")
  farmProfileId  String?   @map("farm_profile_id")
  cropCycleId    String?   @unique @map("crop_cycle_id")
  cropKey        String    @map("crop_key")
  quantity       Float
  unit           String    @default("kg")
  quality        String                                    // high | medium | low
  country        String
  stateCode      String?   @map("state_code")
  city           String?
  availableFrom  DateTime? @map("available_from")
  price          Float?
  pricingMode    String    @default("negotiable") @map("pricing_mode") // fixed | negotiable | ask_buyer
  deliveryMode   String    @default("either") @map("delivery_mode")    // pickup | delivery | either
  status         String    @default("draft")                           // draft | active | reserved | sold | closed
  supportConfidence String? @map("support_confidence")                 // high | medium | low
  notes          String?
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  interests      MarketInterest[]

  @@index([farmerId],  map: "idx_crop_listing_farmer")
  @@index([cropKey],   map: "idx_crop_listing_crop")
  @@index([country],   map: "idx_crop_listing_country")
  @@index([stateCode], map: "idx_crop_listing_state")
  @@index([status],    map: "idx_crop_listing_status")
  @@index([createdAt], map: "idx_crop_listing_created")
  @@map("crop_listings")
}

// Marketplace v1 — distinct from the legacy BuyerInterest model
// above (which captures a farmer's interest in selling to a buyer
// type). This one is a specific buyer's expression of interest in
// a concrete CropListing, gated on the farmer's acceptance before
// contact reveal.
model MarketInterest {
  id                 String    @id @default(uuid())
  listingId          String    @map("listing_id")
  buyerId            String    @map("buyer_id")
  quantityRequested  Float?    @map("quantity_requested")
  offeredPrice       Float?    @map("offered_price")
  note               String?
  status             String    @default("pending")                  // pending | accepted | declined | expired
  farmerResponseNote String?   @map("farmer_response_note")
  respondedAt        DateTime? @map("responded_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  listing            CropListing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@index([listingId], map: "idx_market_interest_listing")
  @@index([buyerId],   map: "idx_market_interest_buyer")
  @@index([status],    map: "idx_market_interest_status")
  @@map("market_buyer_interests")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  type      String                                    // listing_interest | interest_accepted | interest_declined | …
  title     String
  message   String
  isRead    Boolean  @default(false) @map("is_read")
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId,   isRead],  map: "idx_notification_user_unread")
  @@index([userId,   createdAt], map: "idx_notification_user_time")
  @@map("notifications")
}

// ─── Analytics event log ─────────────────────────────────
// Append-only stream of farmer + buyer events. Used for ops
// dashboards and simple derived metrics (daily return rate,
// task completion rate, harvest-to-listing rate, etc.). No PII
// beyond the userId itself; metadata blob is free-form but should
// stay small.
model EventLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  eventType String   @map("event_type")      // onboarding_completed | task_completed | …
  metadata  Json?
  occurredAt DateTime @default(now()) @map("occurred_at")

  @@index([eventType,  occurredAt], map: "idx_event_log_type_time")
  @@index([userId,     occurredAt], map: "idx_event_log_user_time")
  @@map("event_logs")
}

// Buyer-side preferences. One row per user. Preferred regions are
// a small JSON array of {country, stateCode?} so the buyer can
// bookmark either a whole country or specific states within it.
// When browse filters launch, preferredRegions[0] is the default
// and the filter is pre-filled from it.
model BuyerProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique @map("user_id")
  preferredCountries String[] @default([]) @map("preferred_countries")   // ['US','GH']
  preferredRegions   Json     @default("[]") @map("preferred_regions")   // [{country:'US', stateCode:'MD'}, …]
  expandSearch       Boolean  @default(false) @map("expand_search")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@index([userId], map: "idx_buyer_profile_user")
  @@map("buyer_profiles")
}

model V2PestImage {
  id            String    @id @default(uuid())
  profileId     String    @map("profile_id")
  uploadedBy    String    @map("uploaded_by")
  imageType     String    @map("image_type")         // leaf_closeup | whole_plant | field_wide | hotspot_photo | followup
  imageUrl      String    @map("image_url")
  capturedAt    DateTime? @map("captured_at")
  gpsLat        Float?    @map("gps_lat")
  gpsLng        Float?    @map("gps_lng")
  qualityScore  Float?    @map("quality_score")       // 0–100
  qualityNotes  String?   @map("quality_notes")
  // Image quality enforcement
  blurScore     Float?    @map("blur_score")           // 0–100 (higher = sharper)
  brightnessScore Float?  @map("brightness_score")     // 0–100
  resolutionOk  Boolean   @default(true) @map("resolution_ok")
  qualityPassed Boolean   @default(true) @map("quality_passed")
  rejectionReason String? @map("rejection_reason")     // too_blurry | too_dark | too_bright | low_resolution
  createdAt     DateTime  @default(now()) @map("created_at")

  profile       FarmProfile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  detections    V2ImageDetection[]

  @@index([profileId], map: "idx_v2_pest_image_profile")
  @@index([uploadedBy], map: "idx_v2_pest_image_uploader")
  @@map("v2_pest_images")
}

model V2ImageDetection {
  id                  String   @id @default(uuid())
  imageId             String   @map("image_id")
  likelyIssue         String   @map("likely_issue")       // pest | disease | nutrient_deficiency | water_heat_stress | uncertain
  alternativeIssue    String?  @map("alternative_issue")
  confidenceScore     Float    @map("confidence_score")    // 0–100
  severityScore       Float    @map("severity_score")      // 0–100
  isUncertain         Boolean  @default(false) @map("is_uncertain")
  detectionMetadata   Json?    @map("detection_metadata")  // indicators found: bite_marks, holes, stippling, etc.
  createdAt           DateTime @default(now()) @map("created_at")

  image               V2PestImage @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([imageId], map: "idx_v2_detection_image")
  @@index([likelyIssue], map: "idx_v2_detection_issue")
  @@map("v2_image_detections")
}

model V2PestReport {
  id                String   @id @default(uuid())
  profileId         String   @map("profile_id")
  reportedBy        String   @map("reported_by")
  cropCycleId       String?  @map("crop_cycle_id")
  reportSource      String   @default("farmer_scan") @map("report_source") // farmer_scan | satellite_alert | admin_report | regional_watch
  suspectedIssue    String?  @map("suspected_issue")
  reportConfidence  Float?   @map("report_confidence")
  spreadScope       String?  @map("spread_scope")    // isolated | localized | widespread
  riskLevel         String?  @map("risk_level")       // low | moderate | high | urgent
  riskScore         Float?   @map("risk_score")
  likelyIssue       String?  @map("likely_issue")     // pest | disease | nutrient_deficiency | water_heat_stress | uncertain
  alternativeIssue  String?  @map("alternative_issue")
  confidenceScore   Float?   @map("confidence_score") // 0–100
  isUncertain       Boolean  @default(false) @map("is_uncertain")
  actionGuidance    Json?    @map("action_guidance")   // structured action steps
  notes             String?
  imageIds          String[] @map("image_ids")
  status            String   @default("open")         // open | under_review | confirmed | resolved | false_positive
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  profile               FarmProfile            @relation(fields: [profileId], references: [id], onDelete: Cascade)
  cropCycle             V2CropCycle?           @relation(fields: [cropCycleId], references: [id])
  verificationAnswers   V2VerificationAnswer[]
  treatmentActions      V2TreatmentAction[]
  diagnosisFeedback     V2DiagnosisFeedback[]

  @@index([profileId], map: "idx_v2_pest_report_profile")
  @@index([status], map: "idx_v2_pest_report_status")
  @@index([riskLevel], map: "idx_v2_pest_report_risk")
  @@index([createdAt], map: "idx_v2_pest_report_date")
  @@map("v2_pest_reports")
}

model V2VerificationAnswer {
  id            String   @id @default(uuid())
  pestReportId  String   @map("pest_report_id")
  questionKey   String   @map("question_key")    // leaves_eaten | spreading | insects_visible | widespread | recent_rain | recent_heat
  answerValue   String   @map("answer_value")    // yes | no | unsure
  createdAt     DateTime @default(now()) @map("created_at")

  pestReport    V2PestReport @relation(fields: [pestReportId], references: [id], onDelete: Cascade)

  @@index([pestReportId], map: "idx_v2_verify_report")
  @@map("v2_verification_answers")
}

model V2SatelliteScan {
  id              String   @id @default(uuid())
  profileId       String   @map("profile_id")
  scanDate        DateTime @map("scan_date")
  imagerySource   String   @default("sentinel2") @map("imagery_source")
  cloudCover      Float?   @map("cloud_cover")
  scanConfidence  Float?   @map("scan_confidence")
  rawMetadata     Json?    @map("raw_metadata")
  createdAt       DateTime @default(now()) @map("created_at")

