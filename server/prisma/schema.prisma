generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Organization ──────────────────────────────────────

enum OrganizationType {
  NGO
  LENDER
  COOPERATIVE
  INVESTOR
  DEVELOPMENT_PARTNER
  INTERNAL
}

model Organization {
  id          String            @id @default(uuid())
  name        String
  type        OrganizationType  @default(INTERNAL)
  countryCode String?           @map("country_code")
  regionCode  String?           @map("region_code")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  users                User[]
  farmers              Farmer[]
  programs             Program[]
  approvalRequests     ApprovalRequest[]
  pilotChecklistItems  PilotChecklistItem[]
  issues               Issue[]
  slaConfig            Json?            @map("sla_config")

  @@map("organizations")
}

// ─── Program (org-level grouping) ───────────────────────

model Program {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  name            String
  description     String?
  status          String       @default("active")  // active | completed | archived
  startDate       DateTime?    @map("start_date")
  endDate         DateTime?    @map("end_date")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")

  organization    Organization @relation(fields: [organizationId], references: [id])
  cohorts         Cohort[]
  farmers         Farmer[]

  @@index([organizationId], map: "idx_programs_org")
  @@index([status], map: "idx_programs_status")
  @@map("programs")
}

// ─── Cohort (program sub-group) ─────────────────────────

model Cohort {
  id          String   @id @default(uuid())
  programId   String   @map("program_id")
  name        String
  description String?
  status      String   @default("active")  // active | completed | archived
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  program     Program  @relation(fields: [programId], references: [id])
  farmers     Farmer[]

  @@index([programId], map: "idx_cohorts_program")
  @@index([status], map: "idx_cohorts_status")
  @@map("cohorts")
}

// ─── Enums ──────────────────────────────────────────────

enum UserRole {
  super_admin
  institutional_admin
  reviewer
  field_officer
  investor_viewer
  farmer
}

enum RegistrationStatus {
  pending_approval
  approved
  rejected
  disabled
}

enum LifecycleStage {
  pre_planting
  planting
  vegetative
  flowering
  harvest
  post_harvest
}

enum ApplicationStatus {
  draft
  submitted
  under_review
  needs_more_evidence
  field_review_required
  fraud_hold
  approved
  conditional_approved
  rejected
  escalated
  disbursed
}

enum DecisionType {
  approve
  conditional_approve
  reject
  needs_more_evidence
  field_review_required
  escalate
}

enum FraudRiskLevel {
  low
  medium
  high
  critical
}

enum EvidenceType {
  farm_photo
  id_document
  land_title
  crop_photo
  harvest_receipt
  input_receipt
  other
}

enum FarmActivityType {
  planting
  spraying
  fertilizing
  irrigation
  weeding
  harvesting
  storage
  selling
  pesticide
  other
}

enum ReminderType {
  spraying
  fertilizing
  weeding
  irrigation
  harvesting
  harvest_check
  farm_visit_followup
  evidence_completion
  storage_check
  market_check
  pest_inspection
  drying_reminder
  custom
  general
}

enum NotificationType {
  application_update
  verification_complete
  decision_made
  evidence_needed
  reminder_due
  reminder
  field_visit_scheduled
  harvest_guidance
  storage_alert
  post_harvest
  market
  weather
  buyer_guidance
  system
  general
}

enum StorageMethod {
  sealed_bags
  hermetic_bag
  open_air
  warehouse
  silo
  traditional
  cold_storage
  other
}

enum StorageCondition {
  good
  fair
  poor
  deteriorating
  unknown
}

// ─── SoD / JIT Approval Enums ───────────────────────────

enum ApprovalRequestType {
  season_reopen       // SoD + JIT: reopen a closed/harvested/failed season
  farmer_disable      // SoD: disable a farmer account
  role_escalation     // SoD: assign super_admin or institutional_admin role
  user_org_transfer   // SoD: move a user across organizations
  privileged_reset    // SoD + JIT: force-reset an institutional_admin/super_admin password
}

enum ApprovalStatus {
  pending
  approved
  rejected
  expired
  revoked
  executed
}

// ─── Auth Provider ──────────────────────────────────────

enum AuthProvider {
  local
  google
  microsoft
}

// ─── Onboarding Status ─────────────────────────────────

enum OnboardingStatus {
  not_started
  in_progress
  completed
  abandoned
}

// ─── User ───────────────────────────────────────────────

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String?   @map("password_hash")
  fullName          String    @map("full_name")
  role              UserRole  @default(field_officer)
  active            Boolean   @default(true)
  archivedAt        DateTime? @map("archived_at")
  organizationId    String?   @map("organization_id")
  preferredLanguage String    @default("en") @map("preferred_language")
  lastLoginMethod   String?   @map("last_login_method")
  lastLoginAt       DateTime? @map("last_login_at")
  // ─── MFA ───────────────────────────────────────────────
  mfaEnabled        Boolean   @default(false) @map("mfa_enabled")
  mfaSecret         String?   @map("mfa_secret")         // AES-encrypted TOTP secret
  mfaEnrolledAt     DateTime? @map("mfa_enrolled_at")
  mfaBackupCodes    String[]  @default([]) @map("mfa_backup_codes")  // bcrypt-hashed backup codes
  // ─── Email verification ─────────────────────────────────
  emailVerifiedAt   DateTime? @map("email_verified_at")
  // ─── Token revocation ──────────────────────────────────
  tokenVersion      Int       @default(0) @map("token_version")      // bump on logout/disable
  // ─── Onboarding tracking ──────────────────────────────
  onboardingStatus     OnboardingStatus @default(not_started) @map("onboarding_status")
  onboardingStartedAt  DateTime?        @map("onboarding_started_at")
  onboardedAt          DateTime?        @map("onboarded_at")
  onboardingLastStep   String?          @map("onboarding_last_step")
  onboardingSource     String?          @map("onboarding_source")   // 'self_register', 'admin_invite', 'field_officer', 'ngo'
  // ─── NGO program tracking ─────────────────────────────
  program              String?          // e.g. "Cassava Program"; set when source='ngo'
  timezone             String?                                       // e.g. 'Africa/Nairobi'
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  // Relations
  organization          Organization?       @relation(fields: [organizationId], references: [id])
  onboardingEvents      OnboardingEvent[]
  farmerProfile         Farmer?             @relation("FarmerUserAccount")
  farmersCreated        Farmer[]            @relation("FarmerCreatedBy")
  applicationsCreated   Application[]       @relation("ApplicationCreatedBy")
  reviewAssignments     ReviewAssignment[]  @relation("ReviewAssignedTo")
  fieldAssignments      Application[]       @relation("FieldOfficerAssigned")
  reviewNotes           ReviewNote[]
  auditLogs             AuditLog[]
  fieldVisits           FieldVisit[]
  federatedIdentities   FederatedIdentity[]
  // SoD / JIT approval relations
  approvalRequestsMade     ApprovalRequest[] @relation("ApprovalRequestedBy")
  approvalRequestsApproved ApprovalRequest[] @relation("ApprovalApprovedBy")
  approvalRequestsRevoked  ApprovalRequest[] @relation("ApprovalRevokedBy")
  // Pilot QA
  pilotChecklistItems      PilotChecklistItem[] @relation("PilotChecklistUpdatedBy")
  // Feedback
  feedback                 UserFeedback[]
  // Auth
  passwordResetTokens      PasswordResetToken[]
  sessions                 UserSession[]
  emailVerificationTokens  EmailVerificationToken[]
  farmProfiles             FarmProfile[]           @relation("DirectFarmProfile")
  // Referral
  referralCode             String?   @unique @map("referral_code")
  referredById             String?   @map("referred_by_id")
  referralsGiven           Referral[] @relation("ReferralGiver")
  referralsReceived        Referral[] @relation("ReferralReceiver")
  // Analytics
  analyticsEvents          AnalyticsEvent[]
  // Issues
  issuesReported           Issue[] @relation("IssueReporter")
  issuesAssigned           Issue[] @relation("IssueAssignee")
  issueComments            IssueComment[] @relation("IssueCommenter")
  issueAttachments         IssueAttachment[] @relation("IssueUploader")
  staffNotifications       StaffNotification[] @relation("StaffNotifications")
  notifPreferences         Json?               @map("notif_preferences")
  // ─── Reverse relations for FK fields that reference User by ID ───
  farmersAssigned          Farmer[]            @relation("FarmerAssignedOfficer")
  farmersApproved          Farmer[]            @relation("FarmerApprovedBy")
  officerValidations       OfficerValidation[] @relation("ValidationOfficer")
  autoNotifications        AutoNotification[]  @relation("AutoNotifTargetUser")
  // V2 season engine
  v2Seasons                V2Season[]
  // V2 analytics + support
  v2AnalyticsEvents        V2AnalyticsEvent[]
  v2SupportRequests        V2SupportRequest[]
  // Email logs
  emailLogs                EmailLog[]          @relation("EmailLogUser")
  // Farm task completions
  farmTaskCompletions      V2FarmTaskCompletion[]

  @@index([organizationId], map: "idx_users_org")
  @@index([organizationId, role], map: "idx_users_org_role")
  @@index([active], map: "idx_users_active")
  @@index([onboardingStatus], map: "idx_users_onboarding_status")
  @@map("users")
}

// ─── Password Reset Token ──────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")   // SHA-256 of the raw token
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_pwd_reset_user")
  @@map("password_reset_tokens")
}

// ─── User Session (refresh token rotation) ─────────────

model UserSession {
  id             String    @id @default(uuid())
  userId         String    @map("user_id")
  refreshTokenId String    @unique @map("refresh_token_id")
  userAgent      String?   @map("user_agent")
  ipAddress      String?   @map("ip_address")
  expiresAt      DateTime  @map("expires_at")
  revokedAt      DateTime? @map("revoked_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_sessions_user")
  @@index([expiresAt], map: "idx_sessions_expires")
  @@map("user_sessions")
}

// ─── Email Verification Token ──────────────────────────

model EmailVerificationToken {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_email_verify_user")
  @@map("email_verification_tokens")
}

// ─── Federated Identity ────────────────────────────────

model FederatedIdentity {
  id                String       @id @default(uuid())
  userId            String       @map("user_id")
  provider          AuthProvider
  providerAccountId String       @map("provider_account_id")
  providerEmail     String       @map("provider_email")
  linkedAt          DateTime     @default(now()) @map("linked_at")
  metadata          Json?

  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId], map: "uq_fed_provider_account")
  @@index([userId], map: "idx_fed_user")
  @@map("federated_identities")
}

// ─── Farmer ─────────────────────────────────────────────

model Farmer {
  id                   String              @id @default(uuid())
  fullName             String              @map("full_name")
  phone                String
  phoneVerifiedAt      DateTime?           @map("phone_verified_at")   // set by SMS OTP success; null = unverified (backward-compatible)
  nationalId           String?             @map("national_id")   // unique per org — see @@unique below
  gender               String?             // male, female, other, prefer_not_to_say
  dateOfBirth          DateTime?           @map("date_of_birth")
  region               String
  district             String?
  village              String?
  countryCode          String              @default("KE") @map("country_code")
  regionCode           String?             @map("region_code")
  latitude             Float?
  longitude            Float?
  locationSource       String?             @map("location_source")     // 'gps', 'manual', 'reverse_geocoded'
  geolocationAccuracy  Float?              @map("geolocation_accuracy") // meters
  geolocationCapturedAt DateTime?          @map("geolocation_captured_at")
  preferredLanguage    String              @default("en") @map("preferred_language")
  primaryCrop          String?             @map("primary_crop")
  farmSizeAcres        Float?              @map("farm_size_acres")      // LEGACY: auto-computed from landSizeHectares via fromHectares(); prefer landSizeValue+landSizeUnit
  landSizeValue        Float?              @map("land_size_value")
  landSizeUnit         String?             @map("land_size_unit")       // ACRE | HECTARE | SQUARE_METER
  landSizeHectares     Float?              @map("land_size_hectares")   // normalized value
  yearsExperience      Int?                @map("years_experience")
  deviceId             String?             @map("device_id")
  organizationId       String?             @map("organization_id")
  createdById          String              @map("created_by_id")
  selfRegistered       Boolean             @default(false) @map("self_registered")
  registrationStatus   RegistrationStatus  @default(pending_approval) @map("registration_status")
  userId               String?             @unique @map("user_id")
  approvedAt           DateTime?           @map("approved_at")
  approvedById         String?             @map("approved_by_id")
  rejectedAt           DateTime?           @map("rejected_at")
  rejectionReason      String?             @map("rejection_reason")
  invitedAt            DateTime?           @map("invited_at")
  inviteToken          String?             @unique @map("invite_token")
  inviteExpiresAt      DateTime?           @map("invite_expires_at")
  inviteChannel        String?             @map("invite_channel")        // 'link', 'email', 'phone'
  inviteDeliveryStatus String?             @map("invite_delivery_status") // 'manual_share_ready','email_sent','phone_sent','accepted','expired'
  inviteAcceptedAt     DateTime?           @map("invite_accepted_at")
  inviteResendMeta     Json?               @map("invite_resend_meta")    // { timestamps: number[], totalCount: number, lastResentBy: string }
  assignedOfficerId    String?             @map("assigned_officer_id")
  programId            String?             @map("program_id")
  cohortId             String?             @map("cohort_id")
  duplicateFlag        String?             @map("duplicate_flag")           // 'possible_duplicate' | 'review_needed' | 'cleared' | null
  duplicateOfId        String?             @map("duplicate_of_id")          // farmerId of the suspected original
  duplicateScore       Int?                @map("duplicate_score")          // 0-100 duplicate confidence score
  duplicateSignals     Json?               @map("duplicate_signals")        // ['phone_exact', 'name_fuzzy_region_match', ...]
  duplicateReviewedAt  DateTime?           @map("duplicate_reviewed_at")
  duplicateReviewedBy  String?             @map("duplicate_reviewed_by")    // userId
  currentStage         LifecycleStage      @default(pre_planting) @map("current_stage")
  stageUpdatedAt       DateTime?           @map("stage_updated_at")
  stageSource          String?             @map("stage_source")   // 'activity', 'manual', 'seeded'
  stageConfidence      String?             @map("stage_confidence") // 'high', 'medium', 'low'
  stageCropType        String?             @map("stage_crop_type")
  ageGroup              String?             @map("age_group")              // under_25, 25_35, 36_50, over_50
  onboardingCompletedAt DateTime?          @map("onboarding_completed_at")
  profileImageUrl      String?             @map("profile_image_url")
  profileImageUploadedAt DateTime?         @map("profile_image_uploaded_at")
  profileImageUpdatedBy String?            @map("profile_image_updated_by") // userId — audit trail, no @relation
  createdAt            DateTime            @default(now()) @map("created_at")
  updatedAt            DateTime            @updatedAt @map("updated_at")

  organization        Organization?       @relation(fields: [organizationId], references: [id])
  createdBy           User                @relation("FarmerCreatedBy", fields: [createdById], references: [id])
  userAccount         User?               @relation("FarmerUserAccount", fields: [userId], references: [id])
  assignedOfficer     User?               @relation("FarmerAssignedOfficer", fields: [assignedOfficerId], references: [id])
  approvedBy          User?               @relation("FarmerApprovedBy", fields: [approvedById], references: [id])
  program             Program?            @relation(fields: [programId], references: [id])
  cohort              Cohort?             @relation(fields: [cohortId], references: [id])
  applications        Application[]
  farmActivities      FarmActivity[]
  farmSeasons         FarmSeason[]
  reminders           Reminder[]
  notifications       FarmerNotification[]
  produceStorageStatus ProduceStorageStatus[]
  buyerInterests      BuyerInterest[]
  farmProfiles        FarmProfile[]

  @@index([organizationId], map: "idx_farmers_org")
  @@index([createdById], map: "idx_farmers_created_by")
  @@index([registrationStatus], map: "idx_farmers_reg_status")
  @@index([countryCode], map: "idx_farmers_country")
  @@index([region], map: "idx_farmers_region")
  @@index([currentStage], map: "idx_farmers_stage")
  @@index([assignedOfficerId], map: "idx_farmers_officer")
  @@index([organizationId, assignedOfficerId], map: "idx_farmers_org_officer")
  @@index([organizationId, registrationStatus], map: "idx_farmers_org_reg_status")
  @@index([gender], map: "idx_farmers_gender")
  @@index([organizationId, gender], map: "idx_farmers_org_gender")
  @@index([phone], map: "idx_farmers_phone")
  @@index([programId], map: "idx_farmers_program")
  @@index([cohortId], map: "idx_farmers_cohort")
  @@index([duplicateFlag], map: "idx_farmers_duplicate_flag")
  @@unique([phone, organizationId], map: "uq_farmers_phone_org")
  @@unique([nationalId, organizationId], map: "uq_farmers_nationalid_org")
  @@map("farmers")
}

// ─── Application ────────────────────────────────────────

model Application {
  id                     String            @id @default(uuid())
  farmerId               String            @map("farmer_id")
  createdById            String            @map("created_by_id")
  status                 ApplicationStatus @default(draft)
  cropType               String            @map("crop_type")
  farmSizeAcres          Float             @map("farm_size_acres")
  requestedAmount        Float             @map("requested_amount")
  recommendedAmount      Float?            @map("recommended_amount")
  currencyCode           String            @default("KES") @map("currency_code")
  purpose                String?
  season                 String?
  assignedReviewerId     String?           @map("assigned_reviewer_id")
  assignedFieldOfficerId String?           @map("assigned_field_officer_id")
  createdAt              DateTime          @default(now()) @map("created_at")
  updatedAt              DateTime          @updatedAt @map("updated_at")

  farmer              Farmer              @relation(fields: [farmerId], references: [id])
  createdBy           User                @relation("ApplicationCreatedBy", fields: [createdById], references: [id])
  assignedFieldOfficer User?              @relation("FieldOfficerAssigned", fields: [assignedFieldOfficerId], references: [id])
  farmLocation        FarmLocation?
  farmBoundary        FarmBoundary?
  evidenceFiles       EvidenceFile[]
  verificationResult  VerificationResult?
  fraudResult         FraudResult?
  decisionResult      DecisionResult?
  benchmarkResult     BenchmarkResult?
  intelligenceResult  IntelligenceResult?
  reviewAssignments   ReviewAssignment[]
  reviewNotes         ReviewNote[]
  auditLogs           AuditLog[]
  fieldVisits         FieldVisit[]

  @@index([farmerId], map: "idx_applications_farmer")
  @@index([createdById], map: "idx_applications_created_by")
  @@index([status], map: "idx_applications_status")
  @@index([assignedReviewerId], map: "idx_applications_reviewer")
  @@index([assignedFieldOfficerId], map: "idx_applications_officer")
  @@index([createdAt], map: "idx_applications_created_at")
  @@index([status, createdAt], map: "idx_applications_status_created")
  @@index([assignedReviewerId, status], map: "idx_applications_reviewer_status")
  @@map("applications")
}

// ─── Farm Location ──────────────────────────────────────

model FarmLocation {
  id              String   @id @default(uuid())
  applicationId   String   @unique @map("application_id")
  latitude        Float
  longitude       Float
  accuracy        Float?
  altitude        Float?
  capturedAt      DateTime @default(now()) @map("captured_at")
  deviceId        String?  @map("device_id")
  gpsMethod       String?  @map("gps_method")

  application     Application @relation(fields: [applicationId], references: [id])

  @@map("farm_locations")
}

// ─── Farm Boundary ──────────────────────────────────────

model FarmBoundary {
  id              String          @id @default(uuid())
  applicationId   String          @unique @map("application_id")
  measuredArea    Float?          @map("measured_area_acres")
  perimeterMeters Float?          @map("perimeter_meters")
  capturedAt      DateTime        @default(now()) @map("captured_at")

  application     Application     @relation(fields: [applicationId], references: [id])
  points          BoundaryPoint[]

  @@map("farm_boundaries")
}

model BoundaryPoint {
  id          String       @id @default(uuid())
  boundaryId  String       @map("boundary_id")
  pointOrder  Int          @map("point_order")
  latitude    Float
  longitude   Float

  boundary    FarmBoundary @relation(fields: [boundaryId], references: [id], onDelete: Cascade)

  @@index([boundaryId], map: "idx_boundary_points_boundary")
  @@map("boundary_points")
}

// ─── Evidence ───────────────────────────────────────────

model EvidenceFile {
  id              String       @id @default(uuid())
  applicationId   String       @map("application_id")
  type            EvidenceType
  filename        String
  originalName    String       @map("original_name")
  mimeType        String       @map("mime_type")
  sizeBytes       Int          @map("size_bytes")
  url             String
  photoHash       String?      @map("photo_hash")
  metadata        Json?
  uploadedAt      DateTime     @default(now()) @map("uploaded_at")

  application     Application  @relation(fields: [applicationId], references: [id])

  @@index([applicationId], map: "idx_evidence_application")
  @@index([photoHash], map: "idx_evidence_hash")
  @@map("evidence_files")
}

// ─── Verification Result ────────────────────────────────

model VerificationResult {
  id                  String   @id @default(uuid())
  applicationId       String   @unique @map("application_id")
  verificationScore   Float    @map("verification_score")
  confidence          String
  recommendation      String
  flags               Json     @default("[]")
  reasons             Json     @default("[]")
  factors             Json     @default("{}")
  intelligenceSummary Json?    @map("intelligence_summary")
  createdAt           DateTime @default(now()) @map("created_at")

  application         Application @relation(fields: [applicationId], references: [id])

  @@map("verification_results")
}

// ─── Fraud Result ───────────────────────────────────────

model FraudResult {
  id                  String         @id @default(uuid())
  applicationId       String         @unique @map("application_id")
  fraudRiskScore      Float          @map("fraud_risk_score")
  fraudRiskLevel      FraudRiskLevel @map("fraud_risk_level")
  action              String
  flags               Json           @default("[]")
  reasons             Json           @default("[]")
  matchedRecords      Json           @default("[]") @map("matched_records")
  intelligenceSummary Json?          @map("intelligence_summary")
  createdAt           DateTime       @default(now()) @map("created_at")

  application         Application    @relation(fields: [applicationId], references: [id])

  @@map("fraud_results")
}

// ─── Decision Result ────────────────────────────────────

model DecisionResult {
  id                      String       @id @default(uuid())
  applicationId           String       @unique @map("application_id")
  decision                DecisionType
  decisionLabel           String       @map("decision_label")
  riskLevel               String       @map("risk_level")
  recommendedAmount       Float?       @map("recommended_amount")
  blockers                Json         @default("[]")
  reasons                 Json         @default("[]")
  nextActions             Json         @default("[]") @map("next_actions")
  createdAt               DateTime     @default(now()) @map("created_at")

  application             Application  @relation(fields: [applicationId], references: [id])

  @@map("decision_results")
}

