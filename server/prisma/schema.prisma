// ─── Email Log ─────────────────────────────────────────────

enum EmailLogStatus {
  queued
  sent
  failed
}

model EmailLog {
  id              String         @id @default(uuid())
  recipient       String
  sender          String
  subject         String
  templateName    String         @map("template_name")
  status          EmailLogStatus @default(queued)
  errorMessage    String?        @map("error_message")
  relatedUserId   String?        @map("related_user_id")
  relatedReportId String?        @map("related_report_id")
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")

  relatedUser     User?          @relation("EmailLogUser", fields: [relatedUserId], references: [id])

  @@index([recipient], map: "idx_email_log_recipient")
  @@index([templateName], map: "idx_email_log_template")
  @@index([status], map: "idx_email_log_status")
  @@index([relatedUserId], map: "idx_email_log_user")
  @@index([createdAt], map: "idx_email_log_created")
  @@map("email_logs")
}

// ─── Yield / Harvest Records (per-farm, multiple over time) ─────
model V2HarvestRecord {
  id                  String   @id @default(uuid())
  farmId              String   @map("farm_id")
  // Optional link to a specific V2CropCycle so harvest totals can be
  // rolled into per-cycle progress. Nullable for legacy rows and
  // for farmers who report a harvest without having started a
  // tracked cycle first.
  cropCycleId         String?  @map("crop_cycle_id")
  cropId              String   @map("crop_id")
  cropLabel           String   @map("crop_label")
  harvestDate         DateTime @map("harvest_date")
  quantityHarvested   Float    @map("quantity_harvested")
  quantityUnit        String   @map("quantity_unit")        // kg | bags | tonnes | crates | bundles
  quantitySold        Float?   @map("quantity_sold")
  quantityStored      Float?   @map("quantity_stored")
  quantityLost        Float?   @map("quantity_lost")
  averageSellingPrice Float?   @map("average_selling_price")
  currency            String?  @map("currency")             // GHS | NGN | KES | TZS | USD | XOF
  qualityGrade        String?  @map("quality_grade")        // A | B | C | poor | good | excellent
  notes               String?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")
  idempotencyKey      String?  @map("idempotency_key")  // Client-generated UUID for dedup
  clientCreatedAt     DateTime? @map("client_created_at") // Timestamp from client device

  farm                FarmProfile @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([cropCycleId], map: "uq_harvest_records_cycle")
  @@index([farmId], map: "idx_harvest_records_farm")
  @@index([farmId, harvestDate], map: "idx_harvest_records_farm_date")
  @@index([cropId], map: "idx_harvest_records_crop")
  @@index([idempotencyKey], map: "idx_harvest_records_idem")
  @@map("harvest_records")
}

// ─── Farm Cost Records (per-farm expenses, multiple over time) ──
model V2FarmCostRecord {
  id          String   @id @default(uuid())
  farmId      String   @map("farm_id")
  date        DateTime
  category    String                        // seeds | fertilizer | pesticide | herbicide | labor | irrigation | transport | storage | equipment | land_preparation | other
  description String
  amount      Float
  currency    String?                       // GHS | NGN | KES | TZS | USD | XOF
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  idempotencyKey   String?  @map("idempotency_key")  // Client-generated UUID for dedup
  clientCreatedAt  DateTime? @map("client_created_at") // Timestamp from client device

  farm        FarmProfile @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@index([farmId], map: "idx_cost_records_farm")
  @@index([farmId, date], map: "idx_cost_records_farm_date")
  @@index([category], map: "idx_cost_records_category")
  @@index([idempotencyKey], map: "idx_cost_records_idem")
